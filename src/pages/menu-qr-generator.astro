---
import BaseLayout from "../layouts/BaseLayout.astro";
import { MenuQrGenerator } from "../components/MenuQrGenerator";
import AffiliateProducts from "../components/AffiliateProducts.astro";
import InternalLinkHub from "../components/InternalLinkHub.astro";

const title = "Restaurant & Cafe Menu Price List QR Maker | Pro UPI QR";
const description = "Create customized, printable restaurant menus, cafe price cards, and salon service catalogs with integrated scan-to-pay UPI QR codes.";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Restaurant Menu Price List QR Maker",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any",
  "url": "https://www.proupiqr.in/menu-qr-generator/",
  "description": description,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "INR"
  }
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <main class="px-4 py-8 md:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl space-y-8">
      <div class="rounded-[2.5rem] border border-white/75 bg-white/86 p-6 sm:p-8 md:p-10 shadow-[0_18px_48px_rgba(17,59,44,0.08)] space-y-4">
        <a href="/" class="text-xs font-bold text-leaf hover:underline">&larr; Back to Main QR Generator</a>
        <div class="inline-flex items-center gap-2 rounded-full bg-mint px-3.5 py-1 text-xs font-bold text-leaf border border-leaf/10">
          Printable Dining & Service Catalogs
        </div>
        <h1 class="text-3xl font-black tracking-tight text-forest sm:text-5xl">Restaurant & Salon Menu Price List Builder</h1>
        <p class="max-w-3xl text-sm sm:text-base leading-relaxed text-forest/75">
          Build a clean price catalog or table menu for cafes, beauty salons, clinics, and food stalls with a scan-to-pay payment QR code.
        </p>
      </div>

      <div class="rounded-[2.5rem] border border-white/75 bg-white/86 p-6 sm:p-8 md:p-10 shadow-[0_18px_48px_rgba(17,59,44,0.08)]">
        <MenuQrGenerator client:only="react" />
      </div>

      <AffiliateProducts />
      <InternalLinkHub />
    </div>
  </main>
</BaseLayout>
