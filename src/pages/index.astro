---
import BaseLayout from "../layouts/BaseLayout.astro";
import { GeneratorForm } from "../components/GeneratorForm";

const title = "Free UPI QR Code Generator for Shops, Donations, Freelancers, Restaurants";
const description =
  "Create a free UPI QR code online for PhonePe, Google Pay, Paytm, BHIM, and scan-to-pay posters. No signup. No login. Mobile-friendly and instant.";

const faqs = [
  {
    question: "How do I generate a free UPI QR code?",
    answer:
      "Enter your payee name and UPI ID, optionally add amount or note, then generate and download your payment QR instantly."
  },
  {
    question: "Does this UPI QR work with PhonePe, Google Pay, and Paytm?",
    answer:
      "Yes. Standard UPI payment links work with most major UPI apps including PhonePe, Google Pay, Paytm, and BHIM."
  },
  {
    question: "Do I need to create an account?",
    answer:
      "No. The generator works without login, signup, or credit card and runs in the browser."
  },
  {
    question: "Can I create a QR with fixed amount?",
    answer:
      "Yes. You can optionally add an amount so customers pay a preset value."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      name: "UPI QR",
      applicationCategory: "BusinessApplication",
      operatingSystem: "Any",
      url: "https://www.upiqr.in/",
      description,
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "INR"
      }
    },
    {
      "@type": "FAQPage",
      mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer
        }
      }))
    }
  ]
};

const useCases = [
  "Shops and kirana stores",
  "Freelancers and consultants",
  "Restaurants and cafes",
  "Temple donation counters",
  "Schools and tuition fees",
  "Events and registrations"
];

const features = [
  {
    title: "Instant browser generation",
    copy: "Build the QR in the browser without login, signup, or waiting for a dashboard."
  },
  {
    title: "Payment-ready UPI format",
    copy: "Add payee name, UPI ID, fixed amount, and note so scanners land on the right payment intent."
  },
  {
    title: "Poster-first design",
    copy: "Start with a QR today, then turn it into standees, donation posters, table cards, and fee collection materials."
  }
];

const templates = [
  {
    name: "Shop Payment Standee",
    value: "Counter-ready display for retail stores, grocery counters, and local shops.",
    bestFor: "Best for: retail cashier counters, grocery shops, and pharmacies.",
    status: "Available now"
  },
  {
    name: "Temple Donation Poster",
    value: "Devotional layout with larger type and donation-first messaging for trust and transparency.",
    bestFor: "Best for: community donation boxes, religious centers, and charity desks.",
    status: "Available now"
  },
  {
    name: "Restaurant Table QR",
    value: "Compact table tent design displaying table numbers and direct dine-in scan-to-pay instructions.",
    bestFor: "Best for: dine-in tables, cafe counters, and food truck displays.",
    status: "Available now"
  },
  {
    name: "Freelancer Payment Card",
    value: "Modern card layout for client billing, repeat services, and instant invoice links.",
    bestFor: "Best for: invoices, digital resumes, portfolio sites, and WhatsApp sharing.",
    status: "Available now"
  },
  {
    name: "Event Pass Ticket",
    value: "Vibrant ticket-stub design featuring event date, venue details, and scan-to-register flow.",
    bestFor: "Best for: ticketing booths, workshops, registrations, and seminar passes.",
    status: "Available now"
  },
  {
    name: "Tuition Fees Card",
    value: "School notebook inspired theme designed for classroom displays, batches, and coaching fee collections.",
    bestFor: "Best for: schools, coaching batches, class notice boards, and tutors.",
    status: "Available now"
  },
  {
    name: "Cab / Taxi Dashboard Card",
    value: "High-contrast driver-friendly dashboard card with large readable taxi/cab credentials.",
    bestFor: "Best for: cab dashboards, auto-rickshaw screens, and delivery riders.",
    status: "Available now"
  },
  {
    name: "Custom Minimalist Card",
    value: "Clean, professional executive card structure for direct fund transfers and formal business needs.",
    bestFor: "Best for: corporate invoices, business cards, and direct fund transfers.",
    status: "Available now"
  }
];

const landingLinks = [
  { href: "/phonepe-qr-generator", label: "PhonePe QR Generator" },
  { href: "/google-pay-qr-generator", label: "Google Pay QR Generator" },
  { href: "/paytm-qr-generator", label: "Paytm QR Generator" },
  { href: "/donation-qr-generator", label: "Donation QR Generator" }
];
---

<BaseLayout title={title} description={description} schema={schema}>
  <main>
    <section class="relative overflow-hidden px-4 pb-18 pt-6 md:px-6 lg:px-8">
      <div class="grid-glow absolute inset-x-0 top-0 h-[28rem]"></div>
      <div class="mx-auto max-w-7xl">
        <header class="mb-8 flex items-center justify-between gap-4 rounded-full border border-white/70 bg-white/65 px-4 py-3 backdrop-blur">
          <a href="/" class="text-lg font-black tracking-tight text-forest">UPI QR</a>
          <nav class="hidden gap-5 text-sm font-semibold text-forest/80 md:flex">
            <a href="#generator">Generator</a>
            <a href="#templates">Templates</a>
            <a href="#faq">FAQ</a>
          </nav>
        </header>

        <div class="grid items-start gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-14">
          <div class="pt-4 min-w-0">
            <p class="inline-flex rounded-full border border-leaf/15 bg-mint px-4 py-2 text-xs font-black uppercase tracking-[0.26em] text-leaf">
              Professional UPI Payment Standees & QR Poster Builder
            </p>
            <h1 class="mt-5 max-w-3xl text-5xl font-black leading-[0.95] tracking-tight text-forest md:text-7xl">
              Free UPI QR Code Generator
            </h1>
            <p class="mt-6 max-w-2xl text-lg leading-8 text-forest/75 md:text-xl">
              Generate a clean UPI QR in seconds, then grow into posters, table cards, donation
              campaigns, and branded payment materials. No signup. No login. No friction.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a
                href="#generator"
                class="rounded-full bg-forest px-6 py-3 text-sm font-bold text-white transition hover:bg-leaf"
              >
                Create your QR now
              </a>
              <a
                href="#templates"
                class="rounded-full border border-forest/10 px-6 py-3 text-sm font-bold text-forest transition hover:bg-white"
              >
                See poster ideas
              </a>
            </div>

            <div class="mt-8 overflow-hidden relative w-full py-3 border-y border-forest/10">
              <div class="flex animate-marquee gap-4 whitespace-nowrap">
                {useCases.map((item) => (
                  <span class="inline-flex items-center gap-2 rounded-full border border-white/80 bg-white/70 px-4 py-2 text-xs font-bold text-forest backdrop-blur">
                    <span class="w-1.5 h-1.5 rounded-full bg-leaf"></span>
                    {item}
                  </span>
                ))}
                {useCases.map((item) => (
                  <span class="inline-flex items-center gap-2 rounded-full border border-white/80 bg-white/70 px-4 py-2 text-xs font-bold text-forest backdrop-blur">
                    <span class="w-1.5 h-1.5 rounded-full bg-leaf"></span>
                    {item}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <div class="hero-card-shadow rounded-[2rem] border border-white/75 bg-white/88 p-4 backdrop-blur md:p-5">
            <div class="rounded-[1.7rem] border border-forest/10 bg-[#f7f3e7] p-4 overflow-hidden">
              <div class="relative flex flex-col md:flex-row items-center justify-center p-6 gap-6 md:gap-0 min-h-[380px] md:min-h-auto">
                {/* Standee Card */}
                <div class="w-full md:w-[220px] rounded-[1.35rem] bg-white p-4 border border-forest/10 shadow-xl transition-all duration-300 hover:scale-105 hover:-rotate-2 hover:z-25 md:rotate-[-4deg] md:translate-x-4">
                  <p class="text-xs font-black uppercase tracking-[0.2em] text-leaf">Standee</p>
                  <div class="mt-3 rounded-[1.1rem] bg-mint p-4">
                    <p class="text-base font-black text-forest text-center">Scan & Pay</p>
                    <div class="mt-3 aspect-square rounded-xl border-2 border-dashed border-forest/20 bg-white flex items-center justify-center text-3xl">📱</div>
                  </div>
                </div>

                {/* Donation Card */}
                <div class="w-full md:w-[220px] rounded-[1.35rem] bg-forest p-4 text-white shadow-xl transition-all duration-300 hover:scale-105 hover:rotate-2 hover:z-25 md:rotate-[4deg] md:-translate-x-4 mt-[-24px] md:mt-0">
                  <p class="text-xs font-black uppercase tracking-[0.2em] text-sun">Donation</p>
                  <div class="mt-3 rounded-[1.1rem] bg-white/10 p-4">
                    <p class="text-base font-black text-center">Support Us</p>
                    <div class="mt-3 aspect-square rounded-xl border-2 border-dashed border-white/20 flex items-center justify-center text-3xl">🙏</div>
                  </div>
                </div>
              </div>
              <p class="mt-4 text-sm leading-7 text-forest/72">
                Print, frame, and place high-resolution payment standees at checkout. Designed to look clean and professional, creating instant trust with your customers.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="generator" class="px-4 py-10 md:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mb-8 max-w-3xl">
          <p class="text-sm font-black uppercase tracking-[0.2em] text-leaf">Generator</p>
          <h2 class="mt-3 text-3xl font-black tracking-tight text-forest md:text-5xl">
            Create a payment-ready UPI QR in under 30 seconds.
          </h2>
          <p class="mt-4 text-lg leading-8 text-forest/72">
            Works for PhonePe, Google Pay, Paytm, BHIM, and other UPI apps that support standard
            `upi://pay` links.
          </p>
        </div>
        <GeneratorForm client:load />
      </div>
    </section>

    <section class="px-4 py-12 md:px-6 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-5 md:grid-cols-3">
        {features.map((feature) => (
          <article class="section-card rounded-[1.75rem] border border-white/75 bg-white/86 p-6">
            <h3 class="text-xl font-black text-forest">{feature.title}</h3>
            <p class="mt-3 text-base leading-7 text-forest/72">{feature.copy}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="templates" class="px-4 py-12 md:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mb-8 max-w-3xl">
          <p class="text-sm font-black uppercase tracking-[0.2em] text-leaf">Templates</p>
          <h2 class="mt-3 text-3xl font-black tracking-tight text-forest md:text-5xl">
            Start with eight ready-to-use payment poster templates.
          </h2>
          <p class="mt-4 text-lg leading-8 text-forest/72">
            Generate once, switch styles instantly, and download a printable payment image for your
            counter, table, donation desk, or client share flow.
          </p>
        </div>

        <div class="relative mx-auto max-w-4xl h-[520px] flex items-center justify-center mt-12 mb-16 overflow-hidden md:overflow-visible px-4" id="template-deck">
          {templates.map((template, idx) => (
            <div 
              data-idx={idx}
              class="template-card absolute w-[290px] sm:w-[320px] md:w-[340px] rounded-[2rem] border border-forest/15 bg-white p-5 shadow-2xl transition-all duration-500 cursor-pointer origin-bottom select-none"
            >
              <div class="flex items-center justify-between border-b border-forest/10 pb-2.5">
                <span class="text-[10px] font-black uppercase tracking-[0.18em] text-leaf">{template.status}</span>
                <span class="rounded-full bg-mint px-2.5 py-0.5 text-[10px] font-bold text-forest">{idx + 1}/8</span>
              </div>
              
              <h3 class="mt-3.5 text-lg font-black text-forest">{template.name}</h3>
              <p class="mt-2 text-xs text-forest/72 leading-relaxed h-[52px] overflow-hidden">{template.value}</p>

              {/* Mini CSS QR Poster Preview with sample images */}
              <div class="mt-4 rounded-2xl bg-cream p-4 border border-forest/5 flex flex-col items-center justify-center min-h-[170px] relative overflow-hidden shadow-inner">
                {/* Shop Standee Preview */}
                {idx === 0 && (
                  <div class="w-full h-full min-h-[140px] flex flex-col items-center justify-between bg-sun rounded-xl p-3 text-forest shadow">
                    <div class="w-full bg-forest text-[8px] font-black py-1 text-center rounded text-white tracking-widest">SCAN & PAY</div>
                    <div class="w-14 h-14 bg-white p-1 rounded border border-forest/10 flex items-center justify-center relative shadow-sm">
                      <div class="grid grid-cols-2 gap-1 w-full h-full p-0.5 opacity-80">
                        <div class="border border-forest w-3 h-3"></div>
                        <div class="border border-forest w-3 h-3 flex items-end justify-end"><div class="bg-forest w-1.5 h-1.5"></div></div>
                        <div class="border border-forest w-3 h-3 flex items-start justify-end"><div class="bg-forest w-1.5 h-1.5"></div></div>
                        <div class="w-3 h-3 bg-forest rounded-sm"></div>
                      </div>
                      <div class="absolute inset-0 m-auto w-3 h-3 bg-white rounded-full flex items-center justify-center shadow-xs text-[6px]">💰</div>
                    </div>
                    <div class="text-[9px] font-bold tracking-tight">GPay / PhonePe / Paytm</div>
                  </div>
                )}
                {/* Temple Donation Preview */}
                {idx === 1 && (
                  <div class="w-full h-full min-h-[140px] flex flex-col items-center justify-between bg-[#ffefe3] border border-orange-200 rounded-xl p-3 text-[#e65c00] shadow">
                    <div class="text-[9px] font-black uppercase tracking-wider">🙏 DEVOTIONAL CONTRIBUTIONS</div>
                    <div class="w-14 h-14 bg-white p-1 rounded border border-orange-100 flex items-center justify-center relative shadow-sm">
                      <div class="grid grid-cols-2 gap-1 w-full h-full p-0.5 opacity-80">
                        <div class="border border-[#e65c00] w-3 h-3"></div>
                        <div class="border border-[#e65c00] w-3 h-3"></div>
                        <div class="border border-[#e65c00] w-3 h-3"></div>
                        <div class="w-3 h-3 bg-[#e65c00]"></div>
                      </div>
                      <div class="absolute inset-0 m-auto w-3 h-3 bg-white rounded-full flex items-center justify-center shadow-xs text-[6px]">🕉️</div>
                    </div>
                    <div class="text-[8px] font-bold text-center">Every contribution supports our temple</div>
                  </div>
                )}
                {/* Restaurant Table Preview */}
                {idx === 2 && (
                  <div class="w-full h-full min-h-[140px] flex flex-col items-center justify-between bg-[#113b2c] rounded-xl p-3 text-white shadow border border-forest/10">
                    <div class="text-[8px] font-black uppercase tracking-widest text-sun">TABLE NO. 07</div>
                    <div class="w-14 h-14 bg-white p-1 rounded flex items-center justify-center relative shadow-sm">
                      <div class="grid grid-cols-2 gap-1 w-full h-full p-0.5 opacity-80">
                        <div class="border border-forest w-3 h-3"></div>
                        <div class="border border-forest w-3 h-3"></div>
                        <div class="border border-forest w-3 h-3"></div>
                        <div class="w-3 h-3 bg-forest"></div>
                      </div>
                      <div class="absolute inset-0 m-auto w-3 h-3 bg-white rounded-full flex items-center justify-center shadow-xs text-[6px]">🍔</div>
                    </div>
                    <div class="text-[8px] font-bold text-sun/90">Scan to View Menu & Pay</div>
                  </div>
                )}
                {/* Freelancer Payment Preview */}
                {idx === 3 && (
                  <div class="w-full h-full min-h-[140px] flex flex-col items-center justify-between bg-[#f3f4f6] border border-neutral-300 rounded-xl p-3 text-neutral-800 shadow">
                    <div class="text-[9px] font-black tracking-widest uppercase text-neutral-500">INVOICE REMITTANCE</div>
                    <div class="w-14 h-14 bg-white p-1 rounded border border-neutral-200 flex items-center justify-center relative shadow-sm">
                      <div class="grid grid-cols-2 gap-1 w-full h-full p-0.5 opacity-80">
                        <div class="border border-neutral-800 w-3 h-3"></div>
                        <div class="border border-neutral-800 w-3 h-3"></div>
                        <div class="border border-neutral-800 w-3 h-3"></div>
                        <div class="w-3 h-3 bg-neutral-800"></div>
                      </div>
                      <div class="absolute inset-0 m-auto w-3 h-3 bg-white rounded-full flex items-center justify-center shadow-xs text-[6px]">💼</div>
                    </div>
                    <div class="text-[7px] font-bold text-neutral-600">Scan code to clear outstanding balance</div>
                  </div>
                )}
                {/* Event Pass Preview */}
                {idx === 4 && (
                  <div class="w-full h-full min-h-[140px] flex flex-col items-center justify-between bg-gradient-to-br from-purple-600 to-indigo-700 rounded-xl p-3 text-white shadow">
                    <div class="text-[8px] font-bold uppercase tracking-wider text-purple-200">🎫 TECH FEST 2026</div>
                    <div class="w-14 h-14 bg-white p-1 rounded flex items-center justify-center relative shadow-sm">
                      <div class="grid grid-cols-2 gap-1 w-full h-full p-0.5 opacity-80">
                        <div class="border border-purple-800 w-3 h-3"></div>
                        <div class="border border-purple-800 w-3 h-3"></div>
                        <div class="border border-purple-800 w-3 h-3"></div>
                        <div class="w-3 h-3 bg-purple-800"></div>
                      </div>
                      <div class="absolute inset-0 m-auto w-3 h-3 bg-white rounded-full flex items-center justify-center shadow-xs text-[6px]">🚀</div>
                    </div>
                    <div class="text-[7px] font-black text-sun tracking-wider">ENTRY TICKET CODE</div>
                  </div>
                )}
                {/* Tuition Fees Preview */}
                {idx === 5 && (
                  <div class="w-full h-full min-h-[140px] flex flex-col items-center justify-between bg-[#fffbeb] border border-amber-200 rounded-xl p-3 text-amber-900 shadow">
                    <div class="text-[9px] font-black tracking-widest uppercase">ACADEMY TUITION</div>
                    <div class="w-14 h-14 bg-white p-1 rounded border border-amber-100 flex items-center justify-center relative shadow-sm">
                      <div class="grid grid-cols-2 gap-1 w-full h-full p-0.5 opacity-80">
                        <div class="border border-amber-900 w-3 h-3"></div>
                        <div class="border border-amber-900 w-3 h-3"></div>
                        <div class="border border-amber-900 w-3 h-3"></div>
                        <div class="w-3 h-3 bg-amber-900"></div>
                      </div>
                      <div class="absolute inset-0 m-auto w-3 h-3 bg-white rounded-full flex items-center justify-center shadow-xs text-[6px]">✏️</div>
                    </div>
                    <div class="text-[8px] font-bold">Class Fee Installment</div>
                  </div>
                )}
                {/* Cab/Taxi Preview */}
                {idx === 6 && (
                  <div class="w-full h-full min-h-[140px] flex flex-col items-center justify-between bg-[#facc15] rounded-xl p-3 text-neutral-900 shadow">
                    <div class="w-full bg-black text-[7px] font-black py-0.5 text-center text-yellow-400 tracking-wider">METRO CAB TRANSIT</div>
                    <div class="w-14 h-14 bg-white p-1 rounded border border-yellow-500 flex items-center justify-center relative shadow-sm">
                      <div class="grid grid-cols-2 gap-1 w-full h-full p-0.5 opacity-80">
                        <div class="border border-neutral-900 w-3 h-3"></div>
                        <div class="border border-neutral-900 w-3 h-3"></div>
                        <div class="border border-neutral-900 w-3 h-3"></div>
                        <div class="w-3 h-3 bg-neutral-900"></div>
                      </div>
                      <div class="absolute inset-0 m-auto w-3 h-3 bg-white rounded-full flex items-center justify-center shadow-xs text-[6px]">🚕</div>
                    </div>
                    <div class="text-[8px] font-bold tracking-tight">Scan to Pay Fare Instantly</div>
                  </div>
                )}
                {/* Custom Minimalist Preview */}
                {idx === 7 && (
                  <div class="w-full h-full min-h-[140px] flex flex-col items-center justify-between bg-[#fafafa] border border-neutral-200 rounded-xl p-3 text-neutral-800 shadow">
                    <div class="text-[8px] font-black uppercase tracking-wider text-neutral-400">MINIMAL DIRECT</div>
                    <div class="w-14 h-14 bg-white p-1 rounded border border-neutral-200 flex items-center justify-center relative shadow-sm">
                      <div class="grid grid-cols-2 gap-1 w-full h-full p-0.5 opacity-80">
                        <div class="border border-neutral-800 w-3 h-3"></div>
                        <div class="border border-neutral-800 w-3 h-3"></div>
                        <div class="border border-neutral-800 w-3 h-3"></div>
                        <div class="w-3 h-3 bg-neutral-800"></div>
                      </div>
                      <div class="absolute inset-0 m-auto w-3 h-3 bg-white rounded-full flex items-center justify-center shadow-xs text-[6px]">⭐</div>
                    </div>
                    <div class="text-[8px] font-bold text-neutral-500">Peer-to-Peer Transfer</div>
                  </div>
                )}
              </div>

              <div class="mt-4 pt-3 border-t border-forest/10 flex items-center justify-between text-[11px] font-bold text-forest/70">
                <span class="truncate max-w-[190px]">{template.bestFor}</span>
                <span class="text-leaf shrink-0 font-black text-xs hover:translate-x-1 transition-transform">Use &rarr;</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="px-4 py-12 md:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl rounded-[2rem] border border-white/75 bg-forest px-6 py-8 text-white md:px-8 md:py-10">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl">
            <p class="text-sm font-black uppercase tracking-[0.2em] text-sun">Universal Scanning</p>
            <h2 class="mt-3 text-3xl font-black tracking-tight md:text-5xl">
              Scan instantly using any UPI payment application.
            </h2>
            <p class="mt-4 text-lg leading-8 text-white/76">
              Our generated QR codes strictly adhere to standard UPI guidelines. Customers can scan and make secure payments instantly using PhonePe, Google Pay, Paytm, BHIM, or any banking app.
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            {landingLinks.map((link) => (
              <a
                href={link.href}
                class="rounded-full border border-white/15 px-4 py-2 text-sm font-bold text-white transition hover:bg-white hover:text-forest"
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="faq" class="px-4 py-14 md:px-6 lg:px-8">
      <div class="mx-auto max-w-5xl">
        <div class="mb-8 max-w-2xl">
          <p class="text-sm font-black uppercase tracking-[0.2em] text-leaf">FAQ</p>
          <h2 class="mt-3 text-3xl font-black tracking-tight text-forest md:text-5xl">
            Questions people ask before trusting a payment QR.
          </h2>
        </div>
        <div class="grid gap-4">
          {faqs.map((faq) => (
            <details class="section-card rounded-[1.5rem] border border-white/75 bg-white/86 p-5">
              <summary class="cursor-pointer list-none text-lg font-black text-forest">
                {faq.question}
              </summary>
              <p class="mt-3 max-w-3xl text-base leading-7 text-forest/72">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    display: flex;
    width: max-content;
    animation: marquee 20s linear infinite;
  }
  .animate-marquee:hover {
    animation-play-state: paused;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-slideDown {
    animation: slideDown 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>

<script>
  function setupDeck() {
    const deck = document.getElementById('template-deck');
    if (!deck) return;
    const cards = Array.from(deck.querySelectorAll('.template-card')) as HTMLElement[];
    let activeIndex = 0;

    function updateCardPositions() {
      const isMobile = window.innerWidth < 640;
      const translateX = isMobile ? 24 : 64;
      const translateY = isMobile ? 8 : 16;
      const rotateDeg = isMobile ? 2.5 : 4.5;

      cards.forEach((card, idx) => {
        let indexOffset = idx - activeIndex;
        
        if (indexOffset < -cards.length / 2) {
          indexOffset += cards.length;
        } else if (indexOffset > cards.length / 2) {
          indexOffset -= cards.length;
        }

        const absOffset = Math.abs(indexOffset);
        
        if (indexOffset === 0) {
          card.style.transform = 'translate(0px, 0px) scale(1) rotate(0deg)';
          card.style.zIndex = '30';
          card.style.opacity = '1';
          card.style.pointerEvents = 'auto';
        } else if (indexOffset > 0 && indexOffset <= 2) {
          const x = indexOffset * translateX;
          const y = indexOffset * translateY;
          const r = indexOffset * rotateDeg;
          card.style.transform = `translate(${x}px, ${y}px) scale(${1 - absOffset * 0.04}) rotate(${r}deg)`;
          card.style.zIndex = String(30 - absOffset);
          card.style.opacity = String(1 - absOffset * 0.15);
          card.style.pointerEvents = 'auto';
        } else if (indexOffset < 0 && indexOffset >= -2) {
          const x = indexOffset * translateX;
          const y = -indexOffset * translateY;
          const r = indexOffset * rotateDeg;
          card.style.transform = `translate(${x}px, ${y}px) scale(${1 - absOffset * 0.04}) rotate(${r}deg)`;
          card.style.zIndex = String(30 - absOffset);
          card.style.opacity = String(1 - absOffset * 0.15);
          card.style.pointerEvents = 'auto';
        } else {
          card.style.transform = 'translate(0px, 40px) scale(0.8) rotate(0deg)';
          card.style.zIndex = '5';
          card.style.opacity = '0';
          card.style.pointerEvents = 'none';
        }
      });
    }

    cards.forEach((card) => {
      card.addEventListener('click', () => {
        const idx = parseInt(card.getAttribute('data-idx') || '0', 10);
        activeIndex = idx;
        updateCardPositions();
      });
    });

    updateCardPositions();
    window.addEventListener('resize', updateCardPositions);
  }

  setupDeck();
  document.addEventListener('astro:page-load', setupDeck);
</script>
