---
import BaseLayout from "../layouts/BaseLayout.astro";
import { GeneratorForm } from "../components/GeneratorForm";
import AffiliateProducts from "../components/AffiliateProducts.astro";
import { getFeaturedGuides, guidePath } from "../data/internalLinks";

const title = "Free Universal UPI QR Code Generator | Create UPI QR Code for Shops";
const description =
  "Generate UPI QR code with amount for free. Our universal UPI QR code generator works for Paytm, PhonePe, and GPay. Create your UPI QR code for shops instantly.";

const faqs = [
  {
    question: "How to generate UPI QR code?",
    answer:
      "To generate a UPI QR code, simply enter your payee name and UPI ID in our free UPI QR code generator. You can instantly download the payment QR as a high-resolution image."
  },
  {
    question: "Is this a universal UPI QR code generator?",
    answer:
      "Yes, this is a universal UPI QR code generator. The QR codes created will work seamlessly across all major payment apps including PhonePe, Google Pay (GPay), Paytm, and BHIM."
  },
  {
    question: "How to create UPI QR code with amount?",
    answer:
      "You can easily create a UPI QR code with amount using our tool. Simply enter your fixed price in the 'Amount' field, and the generated UPI QR code will automatically request that exact payment from the customer. Read our guide on generating UPI QR with a fixed amount for billing workflows.",
    answerLink: { href: "/blog/how-to-generate-upi-qr-with-amount/", label: "generating UPI QR with a fixed amount" }
  },
  {
    question: "What is UPI QR code?",
    answer:
      "A UPI QR code is a scannable barcode that contains your Virtual Payment Address (VPA) and banking details securely. When scanned by any UPI payment app, it allows the customer to transfer money directly to your bank account."
  },
  {
    question: "How to get UPI QR code for shop?",
    answer:
      "To get a UPI QR code for your shop, enter your merchant UPI ID into our generator. Select a professional poster template, click generate, and print the resulting standee for your billing counter. Our standee printing guide covers sizing, DPI, and laminate choices.",
    answerLink: { href: "/blog/how-to-create-print-upi-qr-code-standee/", label: "standee printing guide" }
  },
  {
    question: "How to get UPI ID from QR code?",
    answer:
      "To get a UPI ID from an existing QR code, simply scan it using any standard QR code reader app on your phone. The text result will be a 'upi://pay' link. Your UPI ID is the part immediately following 'pa=' in that link."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      name: "Pro UPI QR",
      applicationCategory: "BusinessApplication",
      operatingSystem: "Any",
      url: "https://www.proupiqr.in/",
      description,
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "INR"
      }
    },
    {
      "@type": "FAQPage",
      mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer
        }
      }))
    }
  ]
};

const useCases = [
  "Shops and kirana stores",
  "Freelancers and consultants",
  "Restaurants and cafes",
  "Temple donation counters",
  "Schools and tuition fees",
  "Events and registrations"
];

const features = [
  {
    title: "Instant browser generation",
    copy: "Build the QR in the browser without login, signup, or waiting for a dashboard."
  },
  {
    title: "Payment-ready UPI format",
    copy: "Add payee name, UPI ID, fixed amount, and note so scanners land on the right payment intent."
  },
  {
    title: "Poster-first design",
    copy: "Start with a QR today, then turn it into standees, donation posters, table cards, and fee collection materials."
  }
];

const templates = [
  {
    name: "Shop Payment Standee",
    image: "/images/template/abc-shop-standee.png",
    value: "Counter-ready display for retail stores, grocery counters, and local shops.",
    bestFor: "Best for: retail cashier counters, grocery shops, and pharmacies.",
    status: "Available now"
  },
  {
    name: "Temple Donation Poster",
    image: "/images/template/abc-temple-donation.png",
    value: "Devotional layout with larger type and donation-first messaging for trust and transparency.",
    bestFor: "Best for: community donation boxes, religious centers, and charity desks.",
    status: "Available now"
  },
  {
    name: "Restaurant Table QR",
    image: "/images/template/abc-restaurant-table.png",
    value: "Compact table tent design displaying table numbers and direct dine-in scan-to-pay instructions.",
    bestFor: "Best for: dine-in tables, cafe counters, and food truck displays.",
    status: "Available now"
  },
  {
    name: "Freelancer Payment Card",
    image: "/images/template/abc-freelancer-card.png",
    value: "Modern card layout for client billing, repeat services, and instant invoice links.",
    bestFor: "Best for: invoices, digital resumes, portfolio sites, and WhatsApp sharing.",
    status: "Available now"
  },
  {
    name: "Event Pass Ticket",
    image: "/images/template/abc-event-ticket.png",
    value: "Vibrant ticket-stub design featuring event date, venue details, and scan-to-register flow.",
    bestFor: "Best for: ticketing booths, workshops, registrations, and seminar passes.",
    status: "Available now"
  },
  {
    name: "Tuition Fees Card",
    image: "/images/template/abc-custom-minimal.png",
    value: "School notebook inspired theme designed for classroom displays, batches, and coaching fee collections.",
    bestFor: "Best for: schools, coaching batches, class notice boards, and tutors.",
    status: "Available now"
  },
  {
    name: "Cab / Taxi Dashboard Card",
    image: "/images/template/abc-taxi-cab.png",
    value: "High-contrast driver-friendly dashboard card with large readable taxi/cab credentials.",
    bestFor: "Best for: cab dashboards, auto-rickshaw screens, and delivery riders.",
    status: "Available now"
  },
  {
    name: "Custom Minimalist Card",
    image: "/images/template/abc-custom-minimal.png",
    value: "Clean, professional executive card structure for direct fund transfers and formal business needs.",
    bestFor: "Best for: corporate invoices, business cards, and direct fund transfers.",
    status: "Available now"
  }
];

const landingLinks = [
  { href: "/phonepe-qr-generator/", label: "PhonePe QR Generator" },
  { href: "/google-pay-qr-generator/", label: "Google Pay QR Generator" },
  { href: "/paytm-qr-generator/", label: "Paytm QR Generator" },
  { href: "/donation-qr-generator/", label: "Donation QR Generator" }
];

const featuredGuides = getFeaturedGuides(6);
---

<BaseLayout title={title} description={description} schema={schema}>
  <main>
    <section class="relative overflow-hidden px-4 pb-24 md:pb-32 pt-12 md:px-6 lg:px-8">
      <div class="grid-glow absolute inset-x-0 top-0 h-[28rem]"></div>
      <div class="mx-auto max-w-7xl">

        <div class="grid items-start gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-14">
