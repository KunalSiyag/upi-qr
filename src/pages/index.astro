            <p class="mt-3 text-base leading-7 text-forest/72">{feature.copy}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="templates" class="scroll-mt-28 relative z-20 px-4 py-12 md:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mb-8 max-w-3xl">
          <p class="text-sm font-black uppercase tracking-[0.2em] text-leaf">Templates</p>
          <h2 class="mt-3 text-3xl font-black tracking-tight text-forest md:text-5xl">
            Start with eight ready-to-use payment poster templates.
          </h2>
          <p class="mt-4 text-lg leading-8 text-forest/72">
            Generate once, switch styles instantly, and download a printable payment image for your
            counter, table, donation desk, or client share flow.
          </p>
        </div>

        <div class="relative isolate mx-auto mt-12 mb-16 flex min-h-[760px] max-w-4xl items-center justify-center overflow-visible px-4 sm:min-h-[520px]" id="template-deck">
          {templates.map((template, idx) => (
            <div 
              data-idx={idx}
              class="template-card absolute w-[290px] sm:w-[320px] md:w-[340px] rounded-[2rem] border border-forest/15 bg-white p-5 shadow-2xl transition-all duration-500 cursor-pointer origin-bottom select-none will-change-transform"
