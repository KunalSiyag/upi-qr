            </a>
          ))}
        </div>

        <a href="/blog/" class="mt-8 inline-block text-sm font-bold text-leaf hover:underline">
          Browse all blog guides &rarr;
        </a>
      </div>
    </section>

    <section id="faq" class="scroll-mt-28 px-4 py-14 md:px-6 lg:px-8">
      <div class="mx-auto max-w-5xl">
        <div class="mb-8 max-w-2xl">
          <p class="text-sm font-black uppercase tracking-[0.2em] text-leaf">FAQ</p>
          <h2 class="mt-3 text-3xl font-black tracking-tight text-forest md:text-5xl">
            Questions people ask before trusting a payment QR.
          </h2>
        </div>
        <div class="grid gap-4">
          {faqs.map((faq) => (
            <details class="section-card rounded-[1.5rem] border border-white/75 bg-white/86 p-5">
              <summary class="cursor-pointer list-none text-lg font-black text-forest">
                {faq.question}
              </summary>
              <p class="mt-3 max-w-3xl text-base leading-7 text-forest/72">
                {faq.answerLink ? (
                  <>
                    {faq.answer.split(faq.answerLink.label)[0]}
                    <a href={faq.answerLink.href} class="text-leaf font-semibold underline hover:text-forest">
                      {faq.answerLink.label}
                    </a>
                    {faq.answer.split(faq.answerLink.label)[1]}
                  </>
                ) : (
                  faq.answer
                )}
              </p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    display: flex;
    width: max-content;
    animation: marquee 20s linear infinite;
  }
  .animate-marquee:hover {
    animation-play-state: paused;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-slideDown {
    animation: slideDown 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>

<script>
  function setupDeck() {
    const deck = document.getElementById('template-deck');
    if (!deck) return;
    const cards = Array.from(deck.querySelectorAll('.template-card')) as HTMLElement[];
    let activeIndex = 0;

    function updateCardPositions() {
      const isMobile = window.innerWidth < 640;
      const translateX = isMobile ? 24 : 64;
      const translateY = isMobile ? 8 : 16;
      const rotateDeg = isMobile ? 2.5 : 4.5;

      cards.forEach((card, idx) => {
        let indexOffset = idx - activeIndex;
        
        if (indexOffset < -cards.length / 2) {
          indexOffset += cards.length;
        } else if (indexOffset > cards.length / 2) {
          indexOffset -= cards.length;
        }

        const absOffset = Math.abs(indexOffset);
        
        if (indexOffset === 0) {
          card.style.transform = 'translate(0px, 0px) scale(1) rotate(0deg)';
          card.style.zIndex = '30';
          card.style.opacity = '1';
          card.style.pointerEvents = 'auto';
        } else if (indexOffset > 0 && indexOffset <= 2) {
          const x = indexOffset * translateX;
          const y = indexOffset * translateY;
          const r = indexOffset * rotateDeg;
          card.style.transform = `translate(${x}px, ${y}px) scale(${1 - absOffset * 0.04}) rotate(${r}deg)`;
          card.style.zIndex = String(30 - absOffset);
          card.style.opacity = String(1 - absOffset * 0.15);
          card.style.pointerEvents = 'auto';
        } else if (indexOffset < 0 && indexOffset >= -2) {
          const x = indexOffset * translateX;
          const y = -indexOffset * translateY;
          const r = indexOffset * rotateDeg;
          card.style.transform = `translate(${x}px, ${y}px) scale(${1 - absOffset * 0.04}) rotate(${r}deg)`;
          card.style.zIndex = String(30 - absOffset);
          card.style.opacity = String(1 - absOffset * 0.15);
          card.style.pointerEvents = 'auto';
        } else {
          card.style.transform = 'translate(0px, 40px) scale(0.8) rotate(0deg)';
          card.style.zIndex = '5';
          card.style.opacity = '0';
          card.style.pointerEvents = 'none';
        }
      });
    }

    cards.forEach((card) => {
      card.addEventListener('click', () => {
        const idx = parseInt(card.getAttribute('data-idx') || '0', 10);
        activeIndex = idx;
        updateCardPositions();
      });
    });

    // Add Swipe support for Touch Devices
    let touchStartX = 0;
    let touchEndX = 0;
    let touchStartY = 0;
    let touchEndY = 0;

    deck.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.changedTouches[0].screenX;
      touchStartY = e.changedTouches[0].screenY;
    }, { passive: true });

    deck.addEventListener('touchend', (e: TouchEvent) => {
      touchEndX = e.changedTouches[0].screenX;
      touchEndY = e.changedTouches[0].screenY;
      
      const diffX = touchEndX - touchStartX;
      const diffY = touchEndY - touchStartY;
      const minSwipeDistance = 45;

      // Check if horizontal swipe is larger than vertical scroll
      if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > minSwipeDistance) {
        if (diffX < 0) {
          // Swipe left -> Next card
          activeIndex = (activeIndex + 1) % cards.length;
        } else {
          // Swipe right -> Previous card
          activeIndex = (activeIndex - 1 + cards.length) % cards.length;
        }
        updateCardPositions();
      }
    }, { passive: true });

    // Add Mouse Drag support for Desktop testing/browsers
    let isDragging = false;
    let dragStartX = 0;

    deck.addEventListener('mousedown', (e: MouseEvent) => {
      isDragging = true;
      dragStartX = e.clientX;
      deck.style.cursor = 'grabbing';
    });

    window.addEventListener('mouseup', (e: MouseEvent) => {
      if (!isDragging) return;
      isDragging = false;
      deck.style.cursor = 'default';
      
      const dragEndX = e.clientX;
      const diffX = dragEndX - dragStartX;
      const minSwipeDistance = 45;

      if (Math.abs(diffX) > minSwipeDistance) {
        if (diffX < 0) {
          activeIndex = (activeIndex + 1) % cards.length;
        } else {
          activeIndex = (activeIndex - 1 + cards.length) % cards.length;
        }
        updateCardPositions();
      }
    });

    updateCardPositions();
    window.addEventListener('resize', updateCardPositions);
  }

  setupDeck();
  document.addEventListener('astro:page-load', setupDeck);
</script>
