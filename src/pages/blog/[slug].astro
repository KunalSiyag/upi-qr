---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import InternalLinkHub from "../../components/InternalLinkHub.astro";
import { getGeneratorCtaForTags, getGuidesForTags } from "../../data/internalLinks";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.mdx?$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
import { render } from "astro:content";
const { Content } = await render(post);

const title = `${post.data.title} | Pro UPI QR`;
const description = post.data.description;

const postSlug = post.id.replace(/\.mdx?$/, "");
const generatorCta = getGeneratorCtaForTags(post.data.tags);

// Fetch related posts based on matching tags and publication date
const posts = await getCollection("blog");
const curatedGuides = getGuidesForTags(post.data.tags, { excludeSlug: postSlug, limit: 3 });
const relatedPosts = posts
  .filter((p) => p.id !== post.id)
  .map((p) => {
    const commonTags = p.data.tags.filter((t) => post.data.tags.includes(t)).length;
    return { post: p, score: commonTags };
  })
  .sort((a, b) => b.score - a.score || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 3)
  .map((item) => item.post);

const postImageUrl = post.data.image 
  ? (post.data.image.startsWith("http") ? post.data.image : new URL(post.data.image, Astro.site).toString())
  : new URL("/images/og-image.png", Astro.site).toString();

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  "image": postImageUrl,
  "author": {
    "@type": "Person",
    "name": post.data.author
  },
  "publisher": {
    "@type": "Organization",
    "name": "Pro UPI QR",
    "url": "https://www.proupiqr.in",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.proupiqr.in/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": new URL(Astro.url.pathname, Astro.site).toString()
  }
};
---

<BaseLayout title={title} description={description} schema={schema} image={post.data.image}>
  <main class="mx-auto max-w-4xl px-4 py-16 md:px-6 lg:px-8">
    <article class="rounded-[2.5rem] border border-white/75 bg-white/86 p-6 shadow-[0_18px_48px_rgba(17,59,44,0.08)] md:p-12">
      
      {/* Back to Blog */}
      <div class="mb-8">
        <a href="/blog/" class="text-sm font-bold text-leaf hover:underline">&larr; Back to Blog Guides</a>
      </div>

      {/* Frontmatter Metadata */}
      <header class="border-b border-forest/10 pb-8">
        <div class="flex flex-wrap items-center gap-3 text-xs font-semibold text-forest/50">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
          <span>&bull;</span>
          <span>By {post.data.author}</span>
        </div>

        <h1 class="mt-4 text-3xl font-black leading-tight text-forest md:text-5xl">
          {post.data.title}
        </h1>
        
        <p class="mt-4 text-base font-medium text-forest/72 leading-relaxed">
          {post.data.description}
        </p>

        <div class="mt-6 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="rounded-full bg-mint px-3 py-0.5 text-xs font-bold text-forest">
              #{tag}
            </span>
          ))}
        </div>
      </header>

      {/* Rendered Markdown Body Content */}
      <div class="blog-content mt-8">
        <Content />
      </div>

      {/* Author Bio (E-E-A-T) */}
      <div class="mt-12 rounded-2xl bg-mint/30 p-6 border border-leaf/10 flex flex-col md:flex-row items-center md:items-start gap-4">
        <div class="h-14 w-14 shrink-0 rounded-full bg-forest text-white flex items-center justify-center text-xl font-black shadow-sm">
          K
        </div>
        <div class="text-center md:text-left">
          <h3 class="text-lg font-black text-forest">Kunal</h3>
          <p class="mt-1 text-sm text-forest/80 leading-relaxed">
            Applied AI developer building specialized utilities and running technical experiments in public.
          </p>
          <div class="mt-3 flex items-center justify-center md:justify-start gap-4 text-sm font-bold text-leaf">
            <a href="https://x.com/kunal_twts" target="_blank" rel="noopener noreferrer" class="hover:underline hover:text-forest">X (Twitter)</a>
            <a href="https://medium.com/@kunal_writes" target="_blank" rel="noopener noreferrer" class="hover:underline hover:text-forest">Medium</a>
          </div>
        </div>
      </div>

      {/* Related Articles */}
      {(curatedGuides.length > 0 || relatedPosts.length > 0) && (
        <div class="mt-12 border-t border-forest/10 pt-10">
          <h3 class="text-2xl font-black text-forest mb-6">Related Articles</h3>
          <div class="grid gap-6 md:grid-cols-3">
            {(curatedGuides.length > 0
              ? curatedGuides.map((guide) => ({
                  href: `/blog/${guide.slug}/`,
                  title: guide.title,
                  description: guide.description,
                  date: null as Date | null,
                }))
              : relatedPosts.map((rPost) => ({
                  href: `/blog/${rPost.id.replace(/\.mdx?$/, "")}/`,
                  title: rPost.data.title,
                  description: rPost.data.description,
                  date: rPost.data.pubDate,
                }))
            ).map((item) => (
              <a
                href={item.href}
                class="group flex flex-col justify-between rounded-2xl border border-forest/5 bg-[#fffdf6] p-5 transition-all duration-300 hover:scale-[1.02] hover:border-leaf/20 hover:shadow-md"
              >
                <div>
                  {item.date && (
                    <span class="text-[10px] font-bold text-forest/40">
                      {item.date.toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })}
                    </span>
                  )}
                  <h4 class={`text-base font-black text-forest group-hover:text-leaf transition-colors line-clamp-2 ${item.date ? "mt-2" : ""}`}>
                    {item.title}
                  </h4>
                  <p class="mt-2 text-xs text-forest/70 line-clamp-3 leading-relaxed">
                    {item.description}
                  </p>
                </div>
                <div class="mt-4 pt-3 border-t border-forest/5 flex items-center justify-between text-[11px] font-bold text-leaf">
                  <span>Read Guide</span>
                  <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <InternalLinkHub variant="both" currentGuide={postSlug} guideLimit={4} />

      {/* Footer CTA */}
      <footer class="mt-12 border-t border-forest/10 pt-8 text-center">
        <h3 class="text-xl font-black text-forest">{generatorCta.headline}</h3>
        <p class="mt-2 text-sm text-forest/70">{generatorCta.description}</p>
        <a
          href={generatorCta.href}
          class="mt-5 inline-block rounded-full bg-forest px-8 py-3 text-sm font-bold text-white transition hover:bg-leaf"
        >
          {generatorCta.label}
        </a>
      </footer>

    </article>
  </main>
</BaseLayout>

<style is:global>
  /* Localized Prose Styling for Rendered Markdown */
  .blog-content {
    color: #16211f;
    font-size: 1rem;
    line-height: 1.8;
    word-break: break-word;
    overflow-wrap: break-word;
  }
  @media (min-width: 768px) {
    .blog-content {
      font-size: 1.0625rem;
    }
  }

  .blog-content p {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .blog-content strong {
    font-weight: 700;
    color: #113b2c;
  }

  .blog-content h2 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #113b2c;
    margin-top: 2.25rem;
    margin-bottom: 1rem;
    line-height: 1.25;
    letter-spacing: -0.02em;
  }
  @media (min-width: 768px) {
    .blog-content h2 {
      font-size: 1.75rem;
    }
  }

  .blog-content h3 {
    font-size: 1.25rem;
    font-weight: 800;
    color: #113b2c;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .blog-content ul, .blog-content ol {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .blog-content ul {
    list-style-type: disc;
  }

  .blog-content ol {
    list-style-type: decimal;
  }

  .blog-content li {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .blog-content a {
    color: #287a57;
    text-decoration: underline;
    font-weight: 600;
  }
  .blog-content a:hover {
    color: #113b2c;
  }

  .blog-content hr {
    border: 0;
    border-top: 1px solid rgba(17, 59, 44, 0.1);
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  /* Table styling */
  .blog-content table {
    width: 100%;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .blog-content th, .blog-content td {
    padding: 0.75rem 1rem;
    border: 1px solid rgba(17, 59, 44, 0.1);
    text-align: left;
  }

  .blog-content th {
    background-color: #dff6e7;
    color: #113b2c;
    font-weight: 800;
  }

  .blog-content td {
    background-color: #fffaf1;
  }

  /* Blockquote block styling */
  .blog-content blockquote {
    border-left: 4px solid #287a57;
    padding-left: 1.25rem;
    font-style: italic;
    color: rgba(22, 33, 31, 0.85);
    margin: 1.5rem 0;
    background-color: rgba(223, 246, 231, 0.35);
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    border-radius: 0 0.75rem 0.75rem 0;
  }

  .blog-content blockquote p {
    margin: 0;
  }

  /* Responsive, styled markdown images */
  .blog-content img {
    max-width: 100%;
    height: auto;
    border-radius: 1.25rem;
    border: 1px solid rgba(17, 59, 44, 0.08);
    box-shadow: 0 10px 32px rgba(17, 59, 44, 0.06);
    margin: 2.25rem auto;
    display: block;
  }
</style>
