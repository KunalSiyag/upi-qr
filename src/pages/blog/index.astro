---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogListing from "../../components/BlogListing.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

const title = "Pro UPI QR Blog - Guides & Tips for Shop Owners, NGOs & Creators";
const description =
  "Read articles, design guides, and printing tips on how to effectively use UPI QR codes for your shop, business, event, or NGO donations.";
---

<BaseLayout title={title} description={description}>
  <main class="mx-auto max-w-5xl px-4 py-16 md:px-6 lg:px-8">
    <BlogListing posts={posts} />
  </main>
</BaseLayout>