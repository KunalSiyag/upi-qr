---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = "Pro UPI QR Blog - Guides & Tips for Shop Owners, NGOs & Creators";
const description =
  "Read articles, design guides, and printing tips on how to effectively use UPI QR codes for your shop, business, event, or NGO donations.";
---

<BaseLayout title={title} description={description}>
  <main class="mx-auto max-w-5xl px-4 py-16 md:px-6 lg:px-8">
    <div class="mb-12">
      <a href="/" class="text-sm font-bold text-leaf hover:underline">&larr; Back to Generator</a>
      <p class="mt-6 text-sm font-black uppercase tracking-[0.2em] text-leaf font-bold">Guides & Insights</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight text-forest md:text-6xl">
        Pro UPI QR Blog
      </h1>
      <p class="mt-4 text-lg leading-8 text-forest/72">
        Learn how to optimize your checkouts, design eye-catching standees, and collect commission-free payments.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {
        sortedPosts.map((post) => (
          <article class="flex flex-col justify-between rounded-[2rem] border border-white/75 bg-white/86 p-6 shadow-[0_18px_48px_rgba(17,59,44,0.06)] transition-all duration-300 hover:scale-[1.02] hover:shadow-[0_24px_60px_rgba(17,59,44,0.1)]">
            <div>
              <div class="flex flex-wrap items-center gap-3 text-xs font-semibold text-forest/50">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
                <span>&bull;</span>
                <span>By {post.data.author}</span>
              </div>

              <h2 class="mt-4 text-2xl font-black text-forest hover:text-leaf transition-colors">
                <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
              </h2>

              <p class="mt-3 text-sm leading-relaxed text-forest/72">
                {post.data.description}
              </p>
            </div>

            <div class="mt-6 pt-4 border-t border-forest/5 flex items-center justify-between">
              <div class="flex gap-2">
                {post.data.tags.map((tag) => (
                  <span class="rounded-full bg-mint px-3 py-0.5 text-[10px] font-bold text-forest">
                    {tag}
                  </span>
                ))}
              </div>
              <a
                href={`/blog/${post.slug}/`}
                class="text-xs font-black text-leaf hover:underline shrink-0"
              >
                Read Article &rarr;
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </main>
</BaseLayout>
