---
import BaseLayout from "../layouts/BaseLayout.astro";
import { DynamicQrGenerator } from "../components/DynamicQrGenerator";
import AffiliateProducts from "../components/AffiliateProducts.astro";
import InternalLinkHub from "../components/InternalLinkHub.astro";

const title = "Dynamic QR Code Generator & Redirect Link Manager | Pro UPI QR";
const description = "Create dynamic QR codes with editable destination URLs and payment links. Update target destinations anytime without reprinting physical posters.";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Dynamic QR Code Generator",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any",
  "url": "https://www.proupiqr.in/dynamic-qr-generator/",
  "description": description,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "INR"
  }
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <main class="px-4 py-8 md:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl space-y-8">
      <div class="rounded-[2.5rem] border border-white/75 bg-white/86 p-6 sm:p-8 md:p-10 shadow-[0_18px_48px_rgba(17,59,44,0.08)] space-y-4">
        <a href="/" class="text-xs font-bold text-leaf hover:underline">&larr; Back to Main QR Generator</a>
        <div class="inline-flex items-center gap-2 rounded-full bg-mint px-3.5 py-1 text-xs font-bold text-leaf border border-leaf/10">
          Editable Redirect QRs
        </div>
        <h1 class="text-3xl font-black tracking-tight text-forest sm:text-5xl">Dynamic QR Code Generator</h1>
        <p class="max-w-3xl text-sm sm:text-base leading-relaxed text-forest/75">
          Generate dynamic short QR codes where you can update the destination URL or UPI ID anytime in your browser without reprinting physical posters or standees.
        </p>
      </div>

      <div class="rounded-[2.5rem] border border-white/75 bg-white/86 p-6 sm:p-8 md:p-10 shadow-[0_18px_48px_rgba(17,59,44,0.08)]">
        <DynamicQrGenerator client:only="react" />
      </div>

      <AffiliateProducts />
      <InternalLinkHub />
    </div>
  </main>
</BaseLayout>
