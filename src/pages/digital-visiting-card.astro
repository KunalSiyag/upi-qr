---
import BaseLayout from "../layouts/BaseLayout.astro";
import { DigitalVisitingCard } from "../components/DigitalVisitingCard";
import AffiliateProducts from "../components/AffiliateProducts.astro";
import InternalLinkHub from "../components/InternalLinkHub.astro";

const title = "Digital Business Card & UPI Contact QR Maker | Pro UPI QR";
const description = "Create customized digital visiting cards with embedded vCard contact download and zero-fee UPI payment QR codes.";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Digital Business Card & UPI Contact QR Maker",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any",
  "url": "https://www.proupiqr.in/digital-visiting-card/",
  "description": description,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "INR"
  }
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <main class="px-4 py-8 md:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl space-y-8">
      <div class="rounded-[2.5rem] border border-white/75 bg-white/86 p-6 sm:p-8 md:p-10 shadow-[0_18px_48px_rgba(17,59,44,0.08)] space-y-4">
        <a href="/" class="text-xs font-bold text-leaf hover:underline">&larr; Back to Main QR Generator</a>
        <div class="inline-flex items-center gap-2 rounded-full bg-mint px-3.5 py-1 text-xs font-bold text-leaf border border-leaf/10">
          Professional Business Card Builder
        </div>
        <h1 class="text-3xl font-black tracking-tight text-forest sm:text-5xl">Digital Business Card with UPI Payment QR</h1>
        <p class="max-w-3xl text-sm sm:text-base leading-relaxed text-forest/75">
          Generate printable 3.5" x 2" business cards featuring downloadable `.vcf` contact QR codes and direct scan-to-pay payment QR codes.
        </p>
      </div>

      <div class="rounded-[2.5rem] border border-white/75 bg-white/86 p-6 sm:p-8 md:p-10 shadow-[0_18px_48px_rgba(17,59,44,0.08)]">
        <DigitalVisitingCard client:only="react" />
      </div>

      <AffiliateProducts />
      <InternalLinkHub />
    </div>
  </main>
</BaseLayout>
