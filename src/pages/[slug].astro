---
import BaseLayout from "../layouts/BaseLayout.astro";
import { GeneratorForm } from "../components/GeneratorForm";
import AffiliateProducts from "../components/AffiliateProducts.astro";
import InternalLinkHub from "../components/InternalLinkHub.astro";
import { getPresetFromSlug, type GeneratorSlug } from "../data/internalLinks";

export async function getStaticPaths() {
  return [
    {
      params: { slug: "phonepe-qr-generator" },
      props: {
        title: "PhonePe QR Generator",
        headline: "Create a free PhonePe compatible UPI QR code",
        presetType: "phonepe",
        intro:
          "Generate a UPI QR that users can scan from PhonePe and other major UPI apps without signup."
      }
    },
    {
      params: { slug: "google-pay-qr-generator" },
      props: {
        title: "Google Pay QR Generator",
        headline: "Create a free Google Pay compatible UPI QR code",
        presetType: "gpay",
        intro:
          "Make a Google Pay friendly UPI payment QR with optional amount and note for faster collections."
      }
    },
    {
      params: { slug: "paytm-qr-generator" },
      props: {
        title: "Paytm QR Generator",
        headline: "Create a free Paytm compatible UPI QR code",
        presetType: "paytm",
        intro:
          "Build a Paytm compatible UPI QR for shops, local businesses, and daily payment collections."
      }
    },
    {
      params: { slug: "donation-qr-generator" },
      props: {
        title: "Donation QR Generator",
        headline: "Create a donation UPI QR for temples, NGOs, and causes",
        presetType: "donation",
        intro:
          "Set up a free donation QR for events, religious institutions, and community fundraising campaigns."
      }
    }
  ];
}

const { title, headline, intro, presetType } = Astro.props;
const description = `${headline}. ${intro}`;
const generatorSlug = Astro.params.slug as GeneratorSlug;
const resolvedPreset = getPresetFromSlug(generatorSlug);

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": `${title} | Pro UPI QR`,
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any",
  "url": new URL(Astro.url.pathname, Astro.site).toString(),
  "description": description,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "INR"
  }
};
---

<BaseLayout title={`${title} | Pro UPI QR`} description={description} schema={schema}>
  <main class="px-4 py-8 md:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl rounded-[2rem] border border-white/75 bg-white/86 p-4 sm:p-6 md:p-8 shadow-[0_18px_48px_rgba(17,59,44,0.08)]">
      <a href="/" class="text-sm font-bold text-leaf hover:underline">&larr; Back to Pro UPI QR Generator</a>
      <p class="mt-6 text-sm font-black uppercase tracking-[0.2em] text-leaf font-bold">Payment Quick-Links</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight text-forest md:text-6xl">{headline}</h1>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-forest/72">{intro}</p>
      
      <div class="mt-5 flex flex-wrap items-center gap-4 text-xs font-semibold text-leaf">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-mint px-3.5 py-1.5 border border-leaf/10">
          <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          100% Privacy: Generated locally in your browser. We never collect, transmit, or store your payment details.
        </span>
      </div>

      <div class="mt-8 pt-6 border-t border-forest/10">
        <GeneratorForm client:load presetType={presetType as any} />
      </div>

      <div class="mt-12 grid gap-4 md:grid-cols-3 border-t border-forest/10 pt-8">
        <div class="rounded-[1.5rem] bg-mint p-5">
          <h2 class="text-lg font-black text-forest">100% Secure Transfers</h2>
          <p class="mt-3 text-sm leading-relaxed text-forest/72">
            All payments are processed peer-to-peer over the NPCI network directly from customer bank to your bank.
          </p>
        </div>
        <div class="rounded-[1.5rem] bg-cream p-5">
          <h2 class="text-lg font-black text-forest">No Commissions</h2>
          <p class="mt-3 text-sm leading-relaxed text-forest/72">
            Pro UPI QR is a completely free utility. We do not intermediate payment services or levy any platform fees.
          </p>
        </div>
        <div class="rounded-[1.5rem] bg-[#f2e5cd] p-5">
          <h2 class="text-lg font-black text-forest">High-Quality Output</h2>
          <p class="mt-3 text-sm leading-relaxed text-forest/72">
            Download clean, high-resolution poster images ready to print or share instantly via email, messaging, or chat.
          </p>
        </div>
      </div>

      <AffiliateProducts />

      <InternalLinkHub
        variant="both"
        currentGenerator={generatorSlug}
        presetType={resolvedPreset}
      />
    </div>
  </main>
</BaseLayout>
