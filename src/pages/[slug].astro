      }
    },
    {
      params: { slug: "amazon-pay-qr-generator" },
      props: {
        title: "Amazon Pay QR Generator",
        headline: "Create an Amazon Pay compatible UPI QR code",
        presetType: "amazon",
        intro: "Generate a custom Amazon Pay compatible UPI QR poster or standee for billing."
      }
    },
    {
      params: { slug: "sbi-qr-generator" },
      props: {
        title: "SBI UPI QR Generator",
        headline: "Create an SBI UPI compatible QR code",
        presetType: "sbi",
        intro: "Generate State Bank of India (SBI) UPI QR codes for merchant checkouts."
      }
    },
    {
      params: { slug: "hdfc-qr-generator" },
      props: {
        title: "HDFC UPI QR Generator",
        headline: "Create an HDFC Bank compatible UPI QR code",
        presetType: "hdfc",
        intro: "Create HDFC Bank compatible payment QR codes for invoices and checkout display."
      }
    },
    {
      params: { slug: "icici-qr-generator" },
      props: {
        title: "ICICI UPI QR Generator",
        headline: "Create an ICICI Bank compatible UPI QR code",
        presetType: "icici",
        intro: "Generate ICICI Bank compatible UPI billing and collection QR codes."
      }
    },
    {
      params: { slug: "axis-qr-generator" },
      props: {
        title: "Axis Bank UPI QR Generator",
        headline: "Create an Axis Bank compatible UPI QR code",
        presetType: "axis",
        intro: "Build Axis Bank compatible UPI payment standees and counter posters."
      }
    },
    {
      params: { slug: "kotak-qr-generator" },
      props: {
        title: "Kotak Bank UPI QR Generator",
        headline: "Create a Kotak Mahindra Bank compatible UPI QR code",
