---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "सेवा की शर्तें | Pro UPI QR";
const description = "Pro UPI QR के लिए सेवा की शर्तें। मानक अनुरूप UPI भुगतान कोड और पोस्टर बनाने के लिए हमारे मुफ्त टूल का उपयोग करें।";
---

<BaseLayout title={title} description={description}>
  <main class="mx-auto max-w-4xl px-4 py-12 md:px-6 lg:px-8">
    <div class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-md md:p-10">
      <a href="/hi/" class="text-sm font-bold text-leaf hover:underline">&larr; जनरेटर पर वापस जाएं</a>
      
      <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-forest md:text-5xl">सेवा की शर्तें</h1>
      <p class="mt-2 text-xs text-forest/50">अंतिम अपडेट: 8 जून, 2026</p>

      <div class="mt-8 space-y-6 text-sm leading-relaxed text-forest/80">
        <section class="space-y-3">
          <h2 class="text-xl font-bold text-forest">1. शर्तों की स्वीकृति</h2>
          <p>
            Pro UPI QR वेबसाइट और टूल ("सेवा") का उपयोग या उपयोग करके, आप इन सेवा शर्तों से बाध्य होने के लिए सहमत होते हैं। यदि आप इन शर्तों से सहमत नहीं हैं, तो आपको हमारी उपयोगिता का उपयोग या उपयोग नहीं करना चाहिए।
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-forest">2. सेवा का विवरण</h2>
          <p>
            Pro UPI QR मानक एकीकृत भुगतान इंटरफ़ेस (UPI) मापदंडों (VPA आईडी, प्राप्तकर्ता का नाम, राशि, नोट) को मानकीकृत QR कोड और कस्टम डिज़ाइन किए गए पोस्टर स्टैंडी में संकलित करने के लिए एक मुफ्त ब्राउज़र-आधारित टूल प्रदान करता है। यह सेवा केवल सुविधा और शैक्षिक उद्देश्यों के लिए प्रदान की जाती है।
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-forest">3. उपयोगकर्ता की जिम्मेदारी और VPA की सटीकता</h2>
          <p>
            आप जनरेटर में दर्ज किए जाने वाले प्राप्तकर्ता के नाम, UPI आईडी (वर्चुअल भुगतान पता/VPA), राशि और नोट की सटीकता सुनिश्चित करने के लिए पूरी तरह से जिम्मेदार हैं। <strong>हम गलत, गलत वर्तनी, या धोखाधड़ी वाले UPI पतों पर भेजे गए लेनदेन के लिए ज़िम्मेदार नहीं हैं।</strong> आपको वाणिज्यिक वातावरण में प्रकाशित करने, प्रिंट करने या रखने से पहले यह सत्यापित करना चाहिए कि QR कोड स्कैन सही मर्चेंट जानकारी प्रदर्शित करता है।
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-forest">4. वारंटी का अस्वीकरण</h2>
          <p>
            यह सेवा "जैसा है" और "जैसा उपलब्ध है" के आधार पर प्रदान की जाती है, बिना किसी प्रकार की वारंटी के। हम यह गारंटी नहीं देते हैं कि जनरेट किए गए QR कोड सभी डिवाइस पर या सभी मोबाइल बैंकिंग सॉफ़्टवेयर के साथ सही ढंग से स्कैन होंगे। हम इस वेबसाइट पर निर्मित QR कोड के उपयोग से उत्पन्न होने वाले विफल भुगतानों, लेनदेन टाइमआउट, बैंकिंग सिस्टम डाउनटाइम, या किसी भी प्रकार के वित्तीय नुकसान के लिए किसी भी देयता को अस्वीकार करते हैं।
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-forest">5. देयता की सीमाएं</h2>
          <p>
            किसी भी स्थिति में Pro UPI QR, इसके डेवलपर्स या सहयोगी किसी भी प्रत्यक्ष, अप्रत्यक्ष, आकस्मिक, विशेष, परिणामी या अनुकरणीय नुकसान के लिए उत्तरदायी नहीं होंगे, जिसमें इस सेवा के उपयोग या असमर्थता के परिणामस्वरूप होने वाले लाभ, सद्भावना, डेटा, या अन्य अमूर्त नुकसान शामिल हैं।
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-forest">6. शर्तों में संशोधन</h2>
          <p>
            हम किसी भी समय इन शर्तों को संशोधित करने या बदलने का अधिकार सुरक्षित रखते हैं। शर्तों में किसी भी बदलाव के बाद वेबसाइट का आपका निरंतर उपयोग उन नई शर्तों की स्वीकृति माना जाएगा।
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-forest">7. संपर्क जानकारी</h2>
          <p>
            इन सेवा शर्तों के संबंध में किसी भी पूछताछ के लिए, कृपया हमसे <a href="mailto:support@proupiqr.in" class="text-leaf underline font-semibold">support@proupiqr.in</a> पर संपर्क करें।
          </p>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>
