---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "गोपनीयता नीति | Pro UPI QR";
const description = "Pro UPI QR जनरेटर के लिए गोपनीयता नीति। हम आपकी गोपनीयता का सम्मान करते हैं और व्यक्तिगत वित्तीय डेटा या लेनदेन की जानकारी एकत्र नहीं करते हैं।";
---

<BaseLayout title={title} description={description}>
  <main class="mx-auto max-w-4xl px-4 py-12 md:px-6 lg:px-8">
    <div class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-md md:p-10">
      <a href="/hi/" class="text-sm font-bold text-leaf hover:underline">&larr; जनरेटर पर वापस जाएं</a>
      
      <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-forest md:text-5xl">गोपनीयता नीति (Privacy Policy)</h1>
      <p class="mt-2 text-xs text-forest/50">अंतिम अपडेट: 8 जून, 2026</p>

      <div class="mt-8 space-y-6 text-sm leading-relaxed text-forest/80">
        <section class="space-y-3">
          <h2 class="text-xl font-bold text-forest">1. परिचय</h2>
          <p>
            Pro UPI QR ("हम," "हमारा," या "हमें") में आपका स्वागत है। हम आपकी व्यक्तिगत गोपनीयता की रक्षा के लिए प्रतिबद्ध हैं। यह गोपनीयता नीति बताती है कि हमारा वेब एप्लिकेशन कैसे संचालित होता है और हमारे डेटा व्यवहार का विवरण देती है। हमारी वेबसाइट और उपकरणों का उपयोग करके, आप इस नीति में वर्णित डेटा प्रथाओं के लिए अपनी सहमति देते हैं।
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-forest">2. भुगतान या लेनदेन डेटा का कोई संग्रह नहीं</h2>
          <p>
            Pro UPI QR एक लोकल-फर्स्ट (local-first) ब्राउज़र उपयोगिता है। <strong>हम कोई भी वित्तीय लेनदेन डेटा, बैंक खाते, UPI पिन या लेनदेन इतिहास एकत्र, संग्रहीत, संसाधित या प्रसारित नहीं करते हैं।</strong> UPI भुगतान QR कोड का निर्माण पूरी तरह से आपके वेब ब्राउज़र के भीतर क्लाइंट-साइड पर होता है। जब उपयोगकर्ता मोबाइल डिवाइस का उपयोग करके QR कोड को स्कैन करते हैं, तो लेनदेन सीधे आपके चयनित बैंक एप्लिकेशन द्वारा सुरक्षित UPI नेटवर्क के माध्यम से संसाधित होता है।
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-forest">3. स्थानीय ब्राउज़र स्टोरेज (ड्राफ्ट दृढ़ता)</h2>
          <p>
            आपकी सुविधा के लिए, हम आपके फॉर्म फ़ील्ड (प्राप्तकर्ता का नाम, UPI आईडी, और लेआउट चयन) को ड्राफ्ट के रूप में सहेजने के लिए आपके ब्राउज़र के स्थानीय स्टोरेज (LocalStorage) का उपयोग करते हैं। यह आपको टैब बंद करने और बाद में बिना दोबारा टाइप किए वापस आने की अनुमति देता है। यह डेटा आपके स्थानीय डिवाइस पर रहता है और हमारे सर्वर पर कभी अपलोड नहीं किया जाता है। आप अपने ब्राउज़र कैश/स्टोरेज को साफ़ करके किसी भी समय इस ड्राफ्ट को साफ़ कर सकते हैं।
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-forest">4. कुकीज़ और विश्लेषणात्मक उपकरण</h2>
          <p>
            हम ट्रैफ़िक का विश्लेषण करने और उपयोगकर्ता अनुभव को बेहतर बनाने में मदद करने के लिए अनाम, समग्र उपयोग के आंकड़े (जैसे, पेज व्यू, सत्र अवधि, डिवाइस प्रकार) एकत्र करने के लिए कुकीज़ और ट्रैकिंग तकनीकों (जैसे कि Google Analytics) का उपयोग कर सकते हैं। ये उपकरण व्यक्तिगत रूप से पहचान योग्य जानकारी एकत्र नहीं करते हैं। यदि आप चाहें तो कुकीज़ को अस्वीकार करने के लिए अपने ब्राउज़र सेटिंग्स को कॉन्फ़िगर कर सकते हैं।
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-forest">5. विज्ञापन (Google AdSense)</h2>
          <p>
            हम अपनी मुफ्त उपयोगिता को वित्तपोषित करने के लिए Google AdSense के माध्यम से तीसरे पक्ष के विज्ञापन प्रदर्शित कर सकते हैं। Google AdSense इस साइट और इंटरनेट पर अन्य साइटों पर उपयोगकर्ताओं की यात्राओं के आधार पर विज्ञापन देने के लिए कुकीज़ (जैसे DoubleClick कुकी) का उपयोग करता है। उपयोगकर्ता Google की विज्ञापन सेटिंग्स पर जाकर व्यक्तिगत विज्ञापनों से बाहर निकल सकते हैं।
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-forest">6. हमसे संपर्क करें</h2>
          <p>
            यदि इस गोपनीयता नीति के संबंध में आपके कोई प्रश्न या प्रतिक्रिया है, तो कृपया हमसे <a href="mailto:support@proupiqr.in" class="text-leaf underline font-semibold">support@proupiqr.in</a> पर बेझिझक संपर्क करें।
          </p>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>
