---
import BaseLayout from "../layouts/BaseLayout.astro";
import { InvoiceGenerator } from "../components/InvoiceGenerator";

const title = "Free UPI Invoice Generator with QR Code PDF | Pro UPI QR";
const description = "Create a professional invoice PDF with an embedded UPI QR code for freelancers, shops, tuition teachers, consultants, and small businesses. Browser-only, no login required.";

const faqs = [
  {
    question: "Can I add an automatic UPI QR code to a PDF invoice?",
    answer: "Yes. Enter your invoice details, UPI ID, amount, GST, discount, and notes. Pro UPI QR generates the payment QR and places it inside a print-ready invoice that you can save as PDF."
  },
  {
    question: "Is the invoice data uploaded to a server?",
    answer: "No. The invoice draft and QR generation run in your browser. Drafts are saved locally on your device so you can continue numbering invoices without creating an account."
  },
  {
    question: "Who should use this UPI invoice generator?",
    answer: "It is useful for freelancers, consultants, home bakers, tuition teachers, clinics, photographers, plumbers, electricians, and shop owners who want customers to scan and pay directly from the invoice."
  },
  {
    question: "Can developers integrate Pro UPI QR into their own apps?",
    answer: "The public API and JavaScript embed are on the roadmap. This invoice tool is the first merchant-workflow module before hosted payment links, bulk QR generation, and API documentation."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "UPI Invoice Generator by Pro UPI QR",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Any",
      "url": "https://www.proupiqr.in/invoice-generator/",
      "description": description,
      "featureList": [
        "Invoice PDF generator",
        "Embedded UPI QR code",
        "GST and discount calculation",
        "Local browser draft saving",
        "Print and save as PDF"
      ],
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "INR" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map((faq) => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
      }))
    },
    {
      "@type": "HowTo",
      "name": "How to create an invoice PDF with UPI QR code",
      "description": "Generate a printable invoice with a UPI payment QR in your browser.",
      "step": [
        { "@type": "HowToStep", "name": "Enter business and customer details" },
        { "@type": "HowToStep", "name": "Add items, GST, discount, and due date" },
        { "@type": "HowToStep", "name": "Review the auto-generated UPI QR" },
        { "@type": "HowToStep", "name": "Print or save the invoice as PDF" }
      ]
    }
  ]
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <main>
    <section class="relative overflow-hidden px-4 pb-12 pt-12 md:px-6 lg:px-8">
      <div class="grid-glow absolute inset-x-0 top-0 h-[24rem]"></div>
      <div class="relative mx-auto max-w-7xl">
        <div class="max-w-4xl">
          <p class="inline-flex rounded-full border border-leaf/15 bg-mint px-4 py-2 text-xs font-black uppercase tracking-[0.26em] text-leaf">Merchant toolkit</p>
          <h1 class="mt-5 text-4xl font-black leading-tight tracking-tight text-forest md:text-6xl">Free UPI invoice generator with QR code PDF</h1>
          <p class="mt-5 max-w-3xl text-lg leading-8 text-forest/75 md:text-xl">Create a professional invoice, calculate GST and discounts, embed a UPI payment QR automatically, then print or save as PDF for WhatsApp, email, or client billing.</p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#invoice-tool" class="rounded-full bg-forest px-6 py-3 text-sm font-bold text-white transition hover:bg-leaf">Create invoice PDF</a>
            <a href="#roadmap" class="rounded-full border border-forest/10 px-6 py-3 text-sm font-bold text-forest transition hover:bg-white">See API roadmap</a>
          </div>
        </div>
      </div>
    </section>

    <section id="invoice-tool" class="scroll-mt-28 px-4 py-10 md:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <InvoiceGenerator client:only="react" />
      </div>
    </section>

    <section id="roadmap" class="px-4 py-14 md:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl rounded-[2rem] border border-white/75 bg-forest p-6 text-white md:p-10">
        <p class="text-sm font-black uppercase tracking-[0.2em] text-sun">Next integrations</p>
        <h2 class="mt-3 text-3xl font-black tracking-tight md:text-5xl">From QR generator to UPI merchant toolkit.</h2>
        <div class="mt-8 grid gap-4 md:grid-cols-3">
          {[
            ["Public API", "Generate PNG, SVG, base64 QR, UPI URI, and invoice PDFs from billing systems and POS apps."],
            ["Payment links", "Create hosted pay pages like /pay/invoice-102 with logo, amount, UPI button, and QR."],
            ["Bulk CSV invoices", "Upload customer or room lists and export hundreds of payment-ready invoices or QR posters."],
            ["JavaScript embed", "Drop a script into any website to render a Pay via UPI widget without backend code."],
            ["Receipt generator", "Mark invoices as paid, add a paid stamp, and export receipt PDFs for customers."],
            ["QR poster redesign", "Upload an existing bank QR image, extract the UPI intent, and turn it into a branded standee."],
          ].map(([heading, copy]) => (
            <article class="rounded-[1.5rem] border border-white/10 bg-white/8 p-5">
              <h3 class="text-xl font-black">{heading}</h3>
              <p class="mt-3 text-sm leading-7 text-white/72">{copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-4 py-14 md:px-6 lg:px-8">
      <div class="mx-auto max-w-5xl">
        <p class="text-sm font-black uppercase tracking-[0.2em] text-leaf">FAQ</p>
        <h2 class="mt-3 text-3xl font-black tracking-tight text-forest md:text-5xl">Invoice QR questions</h2>
        <div class="mt-8 grid gap-4">
          {faqs.map((faq) => (
            <details class="section-card rounded-[1.5rem] border border-white/75 bg-white/86 p-5">
              <summary class="cursor-pointer list-none text-lg font-black text-forest">{faq.question}</summary>
              <p class="mt-3 max-w-3xl text-base leading-7 text-forest/72">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
