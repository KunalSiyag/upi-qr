---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown>;
  image?: string;
}

const { title, description, canonical, schema, image } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = image 
  ? (image.startsWith("http") ? image : new URL(image, Astro.site).toString())
  : new URL("/images/og-image.png", Astro.site).toString();
---

<!doctype html>
<html lang="en" class="w-full max-w-[100vw] overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#113b2c" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Pro UPI QR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    {/* Google Tag (gtag.js) - Google Analytics Tag */}
    {/* Google Analytics - Placeholder (Uncomment and replace G-XXXXXXXXXX when ready)
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
    */}

    {/* Google AdSense - Auto Ads Script Tag - Placeholder (Uncomment and replace ca-pub-XXXXXXXXXXXXXXXX when ready)
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>
    */}
  </head>
  <body class="font-sans text-ink antialiased bg-[#fffdf6] min-h-screen flex flex-col justify-between w-full max-w-[100vw] overflow-x-hidden">
    <div class="sticky top-0 z-50 w-full px-4 pt-4 pb-2 md:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <header class="flex items-center justify-between gap-4 rounded-full border border-white/70 bg-white/65 px-4 py-3 backdrop-blur shadow-[0_8px_30px_rgb(0,0,0,0.04)]">
          <a href="/" class="text-lg font-black tracking-tight text-forest">Pro UPI QR</a>
          <nav class="hidden gap-5 text-sm font-semibold text-forest/80 md:flex">
            <a href="/#generator" class="hover:text-leaf transition-colors">Generator</a>
            <a href="/#templates" class="hover:text-leaf transition-colors">Templates</a>
            <a href="/#faq" class="hover:text-leaf transition-colors">FAQ</a>
            <a href="/blog/" class="hover:text-leaf transition-colors">Blog</a>
          </nav>
        </header>
      </div>
    </div>
    <div class="flex-1 overflow-x-hidden">
      <slot />
    </div>
    <Footer />
  </body>
</html>
