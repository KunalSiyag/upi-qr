---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown>;
  image?: string;
}

const { title, description, canonical, schema, image } = Astro.props;
const normalizedPath = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : Astro.url.pathname + "/";
const canonicalUrl = canonical ?? new URL(normalizedPath, Astro.site).toString();
const ogImageUrl = image 
  ? (image.startsWith("http") ? image : new URL(image, Astro.site).toString())
  : new URL("/images/og-image.png", Astro.site).toString();

const isHindi = Astro.url.pathname.startsWith("/hi");
const generatorPath = isHindi ? "/hi/#generator" : "/#generator";
const templatesPath = isHindi ? "/hi/#templates" : "/#templates";
const faqPath = isHindi ? "/hi/#faq" : "/#faq";
const blogPath = "/blog/";

const isBlogIndex = normalizedPath === "/blog/";
const isBlogPost = normalizedPath.startsWith("/blog/") && !isBlogIndex;

// Blog is English-only; Hindi switcher goes to translated generator hub
let langLink = `/hi${normalizedPath}`;
if (isHindi) {
  langLink = normalizedPath.replace(/^\/hi\//, "/");
  if (langLink === "") langLink = "/";
} else if (isBlogIndex || isBlogPost) {
  langLink = "/hi/";
}
const langLabel = isHindi ? "English" : "हिन्दी";

const hasAlternate = !isBlogIndex && !isBlogPost;
const baseUrl = Astro.site ? Astro.site.toString().replace(/\/$/, "") : "https://www.proupiqr.in";
let englishPath = normalizedPath;
if (isHindi) {
  englishPath = normalizedPath.replace(/^\/hi\//, "/");
  if (englishPath === "") englishPath = "/";
}
const englishUrl = `${baseUrl}${englishPath}`;
let hindiPath = normalizedPath;
if (isBlogIndex || isBlogPost) {
  hindiPath = "/hi/";
} else if (!isHindi) {
  hindiPath = `/hi${normalizedPath}`;
}
const hindiUrl = `${baseUrl}${hindiPath}`;
---

<!doctype html>
<html lang={isHindi ? "hi" : "en"} class="w-full max-w-[100vw] overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {hasAlternate && (
      <link rel="alternate" hreflang="en" href={englishUrl} />
      <link rel="alternate" hreflang="hi" href={hindiUrl} />
      <link rel="alternate" hreflang="x-default" href={englishUrl} />
    )}
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#113b2c" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Pro UPI QR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </head>
  <body class="font-sans text-ink antialiased bg-[#fffdf6] min-h-screen flex flex-col justify-between w-full max-w-[100vw] overflow-x-hidden">
    <div class="fixed top-0 left-0 right-0 z-50 w-full px-4 pt-4 pb-2 md:px-6 lg:px-8 pointer-events-none">
      <div class="mx-auto max-w-7xl">
        <header class="flex items-center justify-between gap-4 rounded-full border border-white/70 bg-white/65 px-4 py-3 backdrop-blur shadow-[0_8px_30px_rgb(0,0,0,0.04)] pointer-events-auto">
          <a href={isHindi ? "/hi/" : "/"} class="text-sm sm:text-lg font-black tracking-tight text-forest shrink-0">Pro UPI QR</a>
          <div class="flex items-center gap-2.5 sm:gap-6">
            <nav class="flex items-center gap-2.5 sm:gap-5 text-[10px] sm:text-xs md:text-sm font-semibold text-forest/80">
              <details class="group relative">
                <summary class="flex cursor-pointer list-none items-center gap-1 rounded-full px-2 py-1 transition-colors hover:bg-mint hover:text-leaf">
                  Tools
                  <span class="text-[9px] transition-transform group-open:rotate-180">▼</span>
                </summary>
                <div class="absolute right-0 top-8 z-50 w-[min(92vw,520px)] rounded-[1.5rem] border border-forest/10 bg-white p-3 text-left shadow-[0_24px_80px_rgba(17,59,44,0.16)] md:left-0 md:right-auto">
                  <div class="grid gap-2 sm:grid-cols-2">
                    <a href="/universal-qr-generator/" class="rounded-2xl bg-mint/70 p-3 transition hover:bg-mint">
                      <span class="block text-sm font-black text-forest">Universal QR Generator</span>
                      <span class="mt-1 block text-[11px] leading-5 text-forest/65">URL, PDF, WiFi, vCard, app, text and more.</span>
                    </a>
                    <a href="/" class="rounded-2xl bg-cream p-3 transition hover:bg-mint">
                      <span class="block text-sm font-black text-forest">UPI QR Generator</span>
                      <span class="mt-1 block text-[11px] leading-5 text-forest/65">Bank account / VPA payment QR with posters.</span>
                    </a>
                    <a href="/invoice-generator/" class="rounded-2xl bg-cream p-3 transition hover:bg-mint">
                      <span class="block text-sm font-black text-forest">Invoice QR PDF</span>
                      <span class="mt-1 block text-[11px] leading-5 text-forest/65">Invoices with embedded UPI QR and GST totals.</span>
                    </a>
                    <a href="/dynamic-qr-generator/" class="rounded-2xl bg-cream p-3 transition hover:bg-mint">
                      <span class="block text-sm font-black text-forest">Dynamic QR Guide</span>
                      <span class="mt-1 block text-[11px] leading-5 text-forest/65">Learn when editable and trackable QR codes help.</span>
                    </a>
                  </div>
                  <div class="mt-2 rounded-2xl border border-forest/10 bg-white px-3 py-2 text-[11px] font-bold text-forest/70">
                    Start with Universal QR for non-payment codes, UPI QR for bank payments, then Invoice QR for client billing.
                  </div>
                </div>
              </details>
              <a href="/universal-qr-generator/" class="hover:text-leaf transition-colors">Universal</a>
              <a href="/invoice-generator/" class="hover:text-leaf transition-colors hidden sm:inline">Invoice</a>
              <a href="/blog/" class="hover:text-leaf transition-colors">Guides</a>
            </nav>
            <span class="text-forest/20">|</span>
            <a href={langLink} class="rounded-full bg-forest/5 border border-forest/10 px-2 py-0.5 sm:px-3 sm:py-1 text-[10px] sm:text-xs font-bold text-forest hover:bg-forest hover:text-white transition-all duration-200 shrink-0">
              {langLabel}
            </a>
          </div>
        </header>
      </div>
    </div>
    <div class="flex-1 overflow-x-hidden pt-24 md:pt-28">
      <slot />
    </div>
    <Footer />
  </body>
</html>
