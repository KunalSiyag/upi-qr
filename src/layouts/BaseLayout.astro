---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown>;
  image?: string;
}

const { title, description, canonical, schema, image } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = image 
  ? (image.startsWith("http") ? image : new URL(image, Astro.site).toString())
  : new URL("/images/og-image.png", Astro.site).toString();

const isHindi = Astro.url.pathname.startsWith("/hi");
const generatorPath = isHindi ? "/hi/#generator" : "/#generator";
const templatesPath = isHindi ? "/hi/#templates" : "/#templates";
const faqPath = isHindi ? "/hi/#faq" : "/#faq";
const blogPath = "/blog/";

// Dynamic language switcher target
const normalizedPath = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : Astro.url.pathname + "/";
const langLink = isHindi 
  ? normalizedPath.replace(/^\/hi\//, "/") 
  : `/hi${normalizedPath}`;
const langLabel = isHindi ? "English" : "हिन्दी";
---

<!doctype html>
<html lang={isHindi ? "hi" : "en"} class="w-full max-w-[100vw] overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#113b2c" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Pro UPI QR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </head>
  <body class="font-sans text-ink antialiased bg-[#fffdf6] min-h-screen flex flex-col justify-between w-full max-w-[100vw] overflow-x-hidden">
    <div class="fixed top-0 left-0 right-0 z-50 w-full px-4 pt-4 pb-2 md:px-6 lg:px-8 pointer-events-none">
      <div class="mx-auto max-w-7xl">
        <header class="flex items-center justify-between gap-4 rounded-full border border-white/70 bg-white/65 px-4 py-3 backdrop-blur shadow-[0_8px_30px_rgb(0,0,0,0.04)] pointer-events-auto">
          <a href={isHindi ? "/hi/" : "/"} class="text-lg font-black tracking-tight text-forest">Pro UPI QR</a>
          <div class="flex items-center gap-4 sm:gap-6">
            <nav class="hidden gap-5 text-sm font-semibold text-forest/80 md:flex">
              <a href={generatorPath} class="hover:text-leaf transition-colors">{isHindi ? "जनरेटर" : "Generator"}</a>
              <a href={templatesPath} class="hover:text-leaf transition-colors">{isHindi ? "टेम्पलेट्स" : "Templates"}</a>
              <a href={faqPath} class="hover:text-leaf transition-colors">{isHindi ? "अक्सर पूछे जाने वाले प्रश्न" : "FAQ"}</a>
              <a href={blogPath} class="hover:text-leaf transition-colors">{isHindi ? "ब्लॉग" : "Blog"}</a>
            </nav>
            <span class="hidden md:inline text-forest/20">|</span>
            <a href={langLink} class="rounded-full bg-forest/5 border border-forest/10 px-3 py-1 text-xs font-bold text-forest hover:bg-forest hover:text-white transition-all duration-200">
              {langLabel}
            </a>
          </div>
        </header>
      </div>
    </div>
    <div class="flex-1 overflow-x-hidden pt-24 md:pt-28">
      <slot />
    </div>
    <Footer />
  </body>
</html>
