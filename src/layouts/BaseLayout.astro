---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import HeaderNav from "../components/HeaderNav.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown>;
  image?: string;
}

const { title, description, canonical, schema, image } = Astro.props;
const normalizedPath = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : Astro.url.pathname + "/";
const canonicalUrl = canonical ?? new URL(normalizedPath, Astro.site).toString();
const ogImageUrl = image 
  ? (image.startsWith("http") ? image : new URL(image, Astro.site).toString())
  : new URL("/images/og-image.png", Astro.site).toString();

const isHindi = Astro.url.pathname.startsWith("/hi");

const isBlogIndex = normalizedPath === "/blog/";
const isBlogPost = normalizedPath.startsWith("/blog/") && !isBlogIndex;

// Blog is English-only; Hindi switcher goes to translated generator hub
let langLink = `/hi${normalizedPath}`;
if (isHindi) {
  langLink = normalizedPath.replace(/^\/hi\//, "/");
  if (langLink === "") langLink = "/";
} else if (isBlogIndex || isBlogPost) {
  langLink = "/hi/";
}
const langLabel = isHindi ? "English" : "हिन्दी";

const hasAlternate = !isBlogIndex && !isBlogPost;
const baseUrl = Astro.site ? Astro.site.toString().replace(/\/$/, "") : "https://www.proupiqr.in";
let englishPath = normalizedPath;
if (isHindi) {
  englishPath = normalizedPath.replace(/^\/hi\//, "/");
  if (englishPath === "") englishPath = "/";
}
const englishUrl = `${baseUrl}${englishPath}`;
let hindiPath = normalizedPath;
if (isBlogIndex || isBlogPost) {
  hindiPath = "/hi/";
} else if (!isHindi) {
  hindiPath = `/hi${normalizedPath}`;
}
const hindiUrl = `${baseUrl}${hindiPath}`;

// Breadcrumb Schema
const breadcrumbItems = [
  { "@type": "ListItem", "position": 1, "name": "Home", "item": baseUrl }
];
if (normalizedPath !== "/") {
  const parts = normalizedPath.split("/").filter(Boolean);
  let currentPath = baseUrl;
  parts.forEach((part, index) => {
    currentPath += `/${part}`;
    const name = part.replace(/-/g, " ").replace(/\b\w/g, l => l.toUpperCase());
    breadcrumbItems.push({
      "@type": "ListItem",
      "position": index + 2,
      "name": name,
      "item": currentPath
    });
  });
}
---

<!doctype html>
<html lang={isHindi ? "hi" : "en"} class="w-full max-w-[100vw] overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    {hasAlternate && (
      <link rel="alternate" hreflang="en" href={englishUrl} />
      <link rel="alternate" hreflang="hi" href={hindiUrl} />
      <link rel="alternate" hreflang="x-default" href={englishUrl} />
    )}
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#113b2c" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Pro UPI QR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="alternate" type="application/rss+xml" title="Pro UPI QR Blog & Guides RSS Feed" href="/rss.xml" />

    <!-- Organization Rich Snippet -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://www.proupiqr.in/#organization",
      "name": "Pro UPI QR",
      "url": "https://www.proupiqr.in/",
      "logo": "https://www.proupiqr.in/favicon.svg",
      "description": "Free universal UPI QR code generator and payment poster builder for Indian bank accounts, shops, freelancers, and businesses."
    })} />

    <!-- WebSite Sitelinks Searchbox Rich Snippet -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Pro UPI QR",
      "url": "https://www.proupiqr.in/",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://www.proupiqr.in/universal-qr-generator/?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    })} />

    <!-- Breadcrumb Rich Snippet -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbItems
    })} />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
    <!-- Service Worker Registration for PWA Offline mode -->
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
  </head>
  <body class="font-sans text-ink antialiased bg-[#fffdf6] min-h-screen flex flex-col justify-between w-full max-w-[100vw] overflow-x-hidden">
    <div class="fixed top-0 left-0 right-0 z-50 w-full px-4 pt-4 pb-2 md:px-6 lg:px-8 pointer-events-none">
      <div class="mx-auto max-w-7xl">
        <HeaderNav isHindi={isHindi} langLink={langLink} langLabel={langLabel} />
      </div>
    </div>
    <div class="flex-1 overflow-x-hidden pt-24 md:pt-28">
      <slot />
    </div>
    <Footer />
  </body>
</html>
