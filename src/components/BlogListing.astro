---
import type { CollectionEntry } from "astro:content";
import { generators, generatorPath } from "../data/internalLinks";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;

const sortedPosts = [...posts].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [...new Set(sortedPosts.flatMap((p) => p.data.tags))].sort();

function postSlug(id: string): string {
  return id.replace(/\.mdx?$/, "");
}
---

<div class="mb-8">
  <a href="/" class="text-sm font-bold text-leaf hover:underline">&larr; Back to Generator</a>
  <p class="mt-6 text-sm font-black uppercase tracking-[0.2em] text-leaf font-bold">Guides & Insights</p>
  <h1 class="mt-3 text-4xl font-black tracking-tight text-forest md:text-6xl">Pro UPI QR Blog</h1>
  <p class="mt-4 text-lg leading-8 text-forest/72">
    Learn how to optimize your checkouts, design eye-catching standees, and collect commission-free payments.
  </p>
</div>

<section class="mb-8 rounded-[2rem] border border-white/75 bg-white/86 p-5 shadow-[0_12px_36px_rgba(17,59,44,0.05)] md:p-6">
  <div class="grid gap-5 md:grid-cols-2">
    <div>
      <label for="blog-search" class="text-sm font-black uppercase tracking-[0.18em] text-leaf">
        Search guides
      </label>
      <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-center">
        <div class="relative flex-1">
          <svg
            class="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-forest/40"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <input
            id="blog-search"
            type="search"
            autocomplete="off"
            placeholder="Search: standee, PhonePe, donation, printing…"
            class="w-full rounded-full border border-forest/10 bg-[#fffdf6] py-3 pl-11 pr-4 text-sm font-medium text-forest outline-none transition focus:border-leaf/40 focus:ring-2 focus:ring-leaf/15"
          />
        </div>
      </div>
    </div>

    <div>
      <label for="blog-tag-select" class="text-sm font-black uppercase tracking-[0.18em] text-leaf">
        Filter by tag
      </label>
      <select
        id="blog-tag-select"
        class="mt-3 w-full appearance-none rounded-full border border-forest/10 bg-[#fffdf6] py-3 pl-5 pr-10 text-sm font-semibold text-forest outline-none transition focus:border-leaf/40 focus:ring-2 focus:ring-leaf/15"
      >
        <option value="">All tags</option>
        {allTags.map((tag) => (
          <option value={tag}>{tag}</option>
        ))}
      </select>
    </div>
  </div>

  <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
    <p class="text-xs font-semibold text-forest/55">
      <span id="blog-result-count">{sortedPosts.length}</span> articles
    </p>
    <button
      id="blog-search-clear"
      type="button"
      class="rounded-full border border-forest/10 px-5 py-2 text-xs font-bold text-forest/70 transition hover:border-leaf/30 hover:text-leaf"
    >
      Clear filters
    </button>
  </div>
</section>

<section class="mb-12 rounded-[2rem] border border-white/75 bg-forest px-6 py-8 text-white md:px-8">
  <p class="text-sm font-black uppercase tracking-[0.2em] text-sun">Free Tools</p>
  <h2 class="mt-3 text-2xl font-black tracking-tight md:text-3xl">
    Generate your UPI QR before you read the guides.
  </h2>
  <p class="mt-3 max-w-2xl text-sm leading-7 text-white/76">
    Each generator is preset for PhonePe, Google Pay, Paytm, or donation posters — then download a print-ready standee.
  </p>
  <div class="mt-6 flex flex-wrap gap-3">
    {
      generators.map((gen) => (
        <a
          href={generatorPath(gen.slug)}
          class="rounded-full border border-white/15 px-4 py-2 text-sm font-bold text-white transition hover:bg-white hover:text-forest"
        >
          {gen.label}
        </a>
      ))
    }
  </div>
</section>

<div
  id="blog-no-results"
  class="hidden mb-8 rounded-2xl border border-forest/10 bg-cream/60 px-6 py-8 text-center text-sm font-medium text-forest/70"
>
  No articles found. Try a different search or tag.
</div>

<div class="grid gap-8 md:grid-cols-2" id="blog-post-grid">
  {
    sortedPosts.map((post) => {
      const slug = postSlug(post.id);
      const searchText = [post.data.title, post.data.description, ...post.data.tags]
        .join(" ")
        .toLowerCase();

      return (
        <article
          class="blog-post-card flex flex-col justify-between rounded-[2rem] border border-white/75 bg-white/86 p-6 shadow-[0_18px_48px_rgba(17,59,44,0.06)] transition-all duration-300 hover:scale-[1.02] hover:shadow-[0_24px_60px_rgba(17,59,44,0.1)]"
          data-search={searchText}
          data-tags={post.data.tags.join("|")}
        >
          <div>
            <div class="flex flex-wrap items-center gap-3 text-xs font-semibold text-forest/50">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
              <span>&bull;</span>
              <span>By {post.data.author}</span>
            </div>

            <h2 class="mt-4 text-2xl font-black text-forest hover:text-leaf transition-colors">
              <a href={`/blog/${slug}/`}>{post.data.title}</a>
            </h2>

            <p class="mt-3 text-sm leading-relaxed text-forest/72">{post.data.description}</p>
          </div>

          <div class="mt-6 pt-4 border-t border-forest/5 flex items-center justify-between">
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="rounded-full bg-mint px-3 py-0.5 text-[10px] font-bold text-forest">
                  {tag}
                </span>
              ))}
            </div>
            <a
              href={`/blog/${slug}/`}
              class="text-xs font-black text-leaf hover:underline shrink-0"
            >
              Read Article &rarr;
            </a>
          </div>
        </article>
      );
    })
  }
</div>

<script>
  function matchesQuery(haystack: string, query: string): boolean {
    const terms = query.trim().toLowerCase().split(/\s+/).filter(Boolean);
    if (terms.length === 0) return true;
    return terms.every((term) => haystack.includes(term));
  }

  function setupBlogSearch() {
    const searchInput = document.getElementById("blog-search") as HTMLInputElement | null;
    const tagSelect = document.getElementById("blog-tag-select") as HTMLSelectElement | null;
    const clearBtn = document.getElementById("blog-search-clear");
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".blog-post-card"));
    const noResults = document.getElementById("blog-no-results");
    const resultCount = document.getElementById("blog-result-count");

    if (!searchInput || !clearBtn || !tagSelect || cards.length === 0) return;

    function applyFilters() {
      const query = searchInput.value.trim().toLowerCase();
      const activeTag = tagSelect.value;
      let visible = 0;

      cards.forEach((card) => {
        const haystack = card.dataset.search ?? "";
        const tags = (card.dataset.tags ?? "").split("|");
        const matchesText = matchesQuery(haystack, query);
        const matchesTag = !activeTag || tags.includes(activeTag);
        const show = matchesText && matchesTag;

        card.classList.toggle("hidden", !show);
        if (show) visible += 1;
      });

      if (resultCount) resultCount.textContent = String(visible);
      noResults?.classList.toggle("hidden", visible > 0);
    }

    searchInput.addEventListener("input", applyFilters);
    tagSelect.addEventListener("change", applyFilters);

    clearBtn.addEventListener("click", () => {
      searchInput.value = "";
      tagSelect.selectedIndex = 0;
      applyFilters();
      searchInput.focus();
    });
  }

  setupBlogSearch();
  document.addEventListener("astro:page-load", setupBlogSearch);
</script>