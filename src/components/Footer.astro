---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-forest/10 bg-cream/40 px-4 py-12 md:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      {/* Brand Section */}
      <div class="space-y-4">
        <a href="/" class="text-xl font-black tracking-tight text-forest">UPI QR</a>
        <p class="text-xs leading-relaxed text-forest/70">
          Create customized, printable UPI payment posters, counter standees, and table cards. Built for local merchants, freelancers, event hosts, and donation campaigns.
        </p>
      </div>

      {/* Quick Links */}
      <div class="space-y-4">
        <h4 class="text-xs font-bold uppercase tracking-wider text-forest/90">Tools</h4>
        <ul class="space-y-2 text-xs font-medium text-forest/75">
          <li><a href="/#generator" class="hover:text-leaf hover:underline">QR Code Generator</a></li>
          <li><a href="/#templates" class="hover:text-leaf hover:underline">Poster Templates</a></li>
          <li><a href="/#faq" class="hover:text-leaf hover:underline">Frequently Asked Questions</a></li>
        </ul>
      </div>

      {/* Compliance Links */}
      <div class="space-y-4">
        <h4 class="text-xs font-bold uppercase tracking-wider text-forest/90">Compliance</h4>
        <ul class="space-y-2 text-xs font-medium text-forest/75">
          <li><a href="/privacy" class="hover:text-leaf hover:underline">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-leaf hover:underline">Terms of Service</a></li>
          <li><a href="/disclaimer" class="hover:text-leaf hover:underline">Disclaimer</a></li>
        </ul>
      </div>

      {/* Support & Contact */}
      <div class="space-y-4">
        <h4 class="text-xs font-bold uppercase tracking-wider text-forest/90">Contact</h4>
        <p class="text-xs text-forest/70 leading-relaxed">
          For business inquiries, support request, or feedback, email us at:
        </p>
        <p class="text-xs font-bold text-forest">
          <a href="mailto:support@upiqr.in" class="hover:underline">support@upiqr.in</a>
        </p>
      </div>
    </div>

    {/* Compliance & Regulatory Disclaimer */}
    <div class="mt-8 border-t border-forest/5 pt-6 text-[10px] leading-relaxed text-forest/60 space-y-3">
      <p>
        <strong>NPCI Disclaimer:</strong> UPI QR is a free independent utility provider and is not affiliated, associated, authorized, endorsed by, or in any way officially connected with the National Payments Corporation of India (NPCI), BHIM, or any government authorities. The official NPCI website can be found at <a href="https://www.npci.org.in" target="_blank" rel="noopener noreferrer" class="underline hover:text-leaf">npci.org.in</a>.
      </p>
      <p>
        <strong>Brand Disclaimer:</strong> All brand names, logos, trademarks, and registered trademarks (including Paytm, PhonePe, Google Pay, GPay) displayed on this website are the property of their respective owners. Use of these names, trademarks, and brands does not imply endorsement, affiliation, or sponsorship.
      </p>
      <p>
        <strong>Safety & Security Note:</strong> Transactions generated by UPI QR codes on this website are processed directly through the standard UPI Unified Payments Interface protocol. Payment validation, processing, and security are handled entirely on the customer's mobile device via their chosen bank/payment app. We do not store, process, intermediate, or track payment details or funds.
      </p>
    </div>

    {/* Copyright Section */}
    <div class="mt-6 flex flex-col items-center justify-between gap-4 border-t border-forest/5 pt-6 text-center text-xs text-forest/65 md:flex-row">
      <p>&copy; {currentYear} UPI QR. Made for local businesses and independent creators.</p>
      <p class="text-[10px] text-forest/50">All payments are subject to terms set by your VPA provider bank.</p>
    </div>
  </div>
</footer>
